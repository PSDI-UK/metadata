                        "dcterms:type": {
                            "skos:prefLabel": "Software",
                            "@type": "skos:Concept",
                            "@id": "http://purl.org/dc/dcmitype/Software"
                        },
                        "dcterms:description": "abcd, Data Management for Machine Learning Interatomic Potentials (MLIP), offers a suite of tools that allow users to programmatically import data from a repository and utilize it on their local infrastructure. This enables exploration of data in ways that would be too resource-intensive for a general service. Designed specifically for machine-learned interatomic potentials, abcd supports both OpenSearch and MongoDB as backend options, giving users flexibility in their setup. The tool is developed in collaboration with the University of Cambridge.",
