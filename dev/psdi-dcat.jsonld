            {
                "@id": "psdiDcat:resource-theme/1c4e7833-32a5-45ce-8c89-b5678de085a5",
                "dcterms:identifier": "https://resources.psdi.ac.uk/resource-theme/1c4e7833-32a5-45ce-8c89-b5678de085a5",
                "@type": "dcat:Catalog",
                "dcterms:title": "PSDI Subscribed Resources",
