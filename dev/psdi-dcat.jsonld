                            "@id": "http://data.europa.eu/8mn/euroscivoc/527ab165-56f2-4020-8975-e7cd3f21d01d"
                        }
                    ],
                    "dcterms:publisher": {
                        "foaf:name": "PSDI",
                        "@type": "foaf:Agent",
                        "@id": "http://www.psdi.ac.uk/"
                    },
                    "dcterms:creator": [
                        {
