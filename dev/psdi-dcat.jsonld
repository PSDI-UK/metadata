                    {
                        "@id": "psdiDcat:tool/f85c7c18-28b4-4efb-8edd-33d472683905",
                        "dcterms:identifier": "https://resources.psdi.ac.uk/tool/f85c7c18-28b4-4efb-8edd-33d472683905",
                        "@type": "psdiDcatExt:Tool",
                        "dcterms:title": "DSync (Data Transfer and Synchronisation) Container (SIF format)",
                        "rdfs:label": "DSync (Data Transfer and Synchronisation) Container (SIF format)",
                        "dcterms:type": {
                            "skos:prefLabel": "Software",
                            "@type": "skos:Concept",
                            "@id": "http://purl.org/dc/dcmitype/Software"
                        },
                        "dcterms:description": "Transferring data is crucial for researchers to share information with colleagues and back up their work. However, setting up specialized software for this can be challenging. The Data Transfer and Synchronisation (DSync) tool simplifies this process by bundling the necessary software for transferring data to and from S3 storage - commonly used in cloud computing - into a single container image which can be run using Apptainer and Singularity. This makes it easier for researchers to manage data transfers without having to install and configure the software themselves.",
                        "dcat:keyword": [
                            "Apptainer",
                            "Singularity",
                            "container",
                            "container image",
                            "S3",
                            "FAIR",
                            "data sharing",
                            "data transfer"
                        ],
                        "dcat:theme": {
                            "skos:prefLabel": "data exchange",
                            "@type": "skos:Concept",
                            "@id": "http://data.europa.eu/8mn/euroscivoc/119b0e70-ed46-44ae-97e9-fe00411af08c"
                        },
                        "dcterms:publisher": {
                            "foaf:name": "PSDI",
                            "@type": "foaf:Agent",
                            "@id": "http://www.psdi.ac.uk/"
                        },
                        "dcterms:creator": [
                            {
                                "foaf:name": "Amali Pawula Hewage",
                                "@type": "foaf:Agent",
                                "@id": "http://www.linkedin.com/in/amali-shashiprabha-rajapaksha"
                            },
                            {
                                "foaf:name": "Tom Underwood",
                                "@type": "foaf:Agent",
                                "@id": "http://orcid.org/0000-0001-6431-0612"
                            }
                        ],
                        "dcat:landingPage": {
                            "rdfs:label": "data-transfer-container github repository",
                            "@type": "foaf:Document",
                            "@id": "https://github.com/PSDI-UK/data-transfer-container"
                        },
                        "dcat:contactPoint": {
                            "@type": "vcard:Kind",
                            "vcard:hasURL": "https://github.com/PSDI-UK/data-transfer-container/issues",
                            "@id": "https://github.com/PSDI-UK/data-transfer-container/issues"
