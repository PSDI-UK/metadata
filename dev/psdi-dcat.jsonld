                    {
                        "@id": "psdiDcat:guidance/cdbcfbaf-90fc-4336-a7bd-ecc8ed8baaf4",
                        "dcterms:identifier": "https://resources.psdi.ac.uk/guidance/cdbcfbaf-90fc-4336-a7bd-ecc8ed8baaf4",
                        "@type": "psdiDcatExt:Guidance",
                        "dcterms:title": "Chemistry and Materials Machine Learning School (CAMML)",
                        "rdfs:label": "CAMML",
                        "dcterms:type": {
                            "skos:prefLabel": "Text",
                            "@type": "skos:Concept",
                            "@id": "http://purl.org/dc/dcmitype/Text"
                        },
                        "dcterms:description": "Training is at the core of this resource theme. The Chemistry and Materials Machine Learning (CaMML) school is run by PSDI in collaboration with a range of communities. Training is targeted towards PhD students, in particular those in the Materials and Molecular Simulations field, who have experience of coding but are not highly experienced with machine learning. The aim of this in-person training is to introduce attendees to the latest methods of machine learning for the atomistic simulation of materials.",
                        "dcat:keyword": [
                            "PSDI-pathfinder",
                            "materials simulations",
                            "molecular simulations"
                        ],
                        "dcat:theme": {
                            "skos:prefLabel": "machine learning",
                            "@type": "skos:Concept",
                            "@id": "http://data.europa.eu/8mn/euroscivoc/527ab165-56f2-4020-8975-e7cd3f21d01d"
                        },
                        "dcterms:publisher": {
