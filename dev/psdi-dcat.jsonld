                "psdiDcatExt:Tool": {
                    "@id": "psdiDcat:tool/323cc7d7-4538-47ca-bdd3-ab02194b7834",
                    "dcterms:identifier": "https://resources.psdi.ac.uk/tool/323cc7d7-4538-47ca-bdd3-ab02194b7834",
                    "@type": "psdiDcatExt:Tool",
                    "dcterms:title": "TEMPOS (Transmission Electron Microscopy Particle Outline Segmentation) Github Repository",
                    "rdfs:label": "TEMPOS Github Repository",
                    "dcterms:type": {
                        "skos:prefLabel": "Software",
                        "@type": "skos:Concept",
                        "@id": "http://purl.org/dc/dcmitype/Software"
                    },
                    "dcterms:description": "TEMPOS is software used to segment TEM nanoparticle images by generating synthetic training data and training segmentation models that underpin the datasets in TEM ParticlesDB. It provides a graphical interface for creating synthetic TEM images, applying contrast transfer functions, training segmentation models, and processing experimental images to produce particle outlines and measurements.\nFor users who want to reproduce or extend the workflow, the repository also includes Jupyter notebooks for segmenting TEM videos, with or without particle tracking, and scripts for running the full method outside the GUI. These materials allow researchers to explore how the segmentation models were trained, adapt the workflow to their own data, or generate additional synthetic datasets for further model development.",
                    "dcat:keyword": [
                        "PSDI-funding-call-FC1-A1-2025",
                        "Transmission Electron Microscopy",
                        "TEM",
                        "nanoparticles",
                        "experimental",
                        "synthetic",
