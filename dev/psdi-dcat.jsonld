                "psdiDcatExt:furtherInformation": {
                    "rdfs:label": "Replicability challenges in redox flow cell testing: Insights from a multi-institutional study",
                    "@type": "rdfs:Resource",
                    "@id": "https://dx.doi.org/10.1039/D5EE07103H"
                },
                "psdiDcatExt:logoURL": {
                    "rdfs:label": "Flow Battery logo",
                    "@type": "rdfs:Resource",
                    "@id": "https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/flowBattery-r.png"
                },
                "psdiDcatExt:displayPriority": 2.0,
                "dcat:Dataset": {
                    "@id": "psdiDcat:data/5b597322-c7d9-4913-98d2-3e4ac313013a",
                    "dcterms:identifier": "https://resources.psdi.ac.uk/data/5b597322-c7d9-4913-98d2-3e4ac313013a",
                    "@type": "dcat:Dataset",
                    "dcterms:title": "Flow Battery Experimental Metadata Repository",
                    "rdfs:label": "Flow Battery Experimental Metadata Repository",
                    "dcterms:type": {
                        "skos:prefLabel": "Dataset",
                        "@type": "skos:Concept",
                        "@id": "http://purl.org/dc/dcmitype/Dataset"
                    },
                    "dcterms:description": "The Flow Battery Experimental Metadata Repository provides a structured place for contributing and viewing metadata about experimental practices, equipment choices, and procedural decisions made during multi-institution flow battery reproducibility studies. \nThese studies bring together several of the world's leading research groups, national laboratories, and industrial partners to understand how experimental practices influence the repeatability, replicability, and reproducibility of flow battery electrochemical testing.\nStructured metadata collection allows researchers to compare approaches, identify factors affecting performance variation, and support the development of more consistent testing methodology. In the longer term, the study aims to provide benchmark datasets for use by the wider community and help new entrants to the field by lowering the barrier to consistent and reliable experimental practices.\nAt present, the catalogue is populated with metadata gathered through the multi-institution \"Phase 2\" studies conducted across 2025/26, with contributions from over approximately 40 participants worldwide. The resource is openly accessible for browsing, allowing the broader community to explore experimental set-ups and methodological variability.\nIn future phases, the catalogue will be open to submissions from the wider community and anticipate running further benchmarking studies to expand the collection. The repository is supported and hosted by PSDI partners on behalf of the flow battery research community.",
                    "dcat:keyword": [
                        "PSDI-funding-call-FC1-2025",
                        "flow battery",
                        "reproducibility",
                        "electrochemical testing",
                        "electrochemistry"
                    ],
