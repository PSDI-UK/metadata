                    {
                        "@id": "psdiDcat:tool/099911e7-a350-44b7-8add-2cba64beb8d8",
                        "dcterms:identifier": "https://resources.psdi.ac.uk/tool/099911e7-a350-44b7-8add-2cba64beb8d8",
                        "@type": "psdiDcatExt:Tool",
                        "dcterms:title": "Metadise Container (Docker format)",
                        "rdfs:label": "Metadise Container (Docker format)",
                        "dcterms:type": {
                            "skos:prefLabel": "Software",
                            "@type": "skos:Concept",
                            "@id": "http://purl.org/dc/dcmitype/Software"
                        },
                        "dcterms:description": "This container image enables users to run the computational chemistry program Metadise on their own computing infrastructure using Docker. Metadise stands for 'Minimum Energy Technique Applied to Dislocation, Interface and Surface Energies'. The program has multiple uses. For instance it can be used to model dislocations, surfaces and grain boundaries at the atomic scale using force fields; and it can be used to create input files for other computational chemistry programs. This container image enables users to use Metadise directly with Metadise input files, removing the need to manually compile Metadise from its source code.",
