                    {
                        "@id": "psdiDcat:tool/f988614a-ab07-4fb6-b0ee-83f19024399d",
                        "dcterms:identifier": "https://resources.psdi.ac.uk/tool/f988614a-ab07-4fb6-b0ee-83f19024399d",
