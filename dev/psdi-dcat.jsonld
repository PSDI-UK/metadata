                "psdiDcatExt:Guidance": {
                    "@id": "psdiDcat:guidance/5cd98f00-05d6-4133-858e-d6fadc3d8655",
                    "dcterms:identifier": "https://resources.psdi.ac.uk/guidance/5cd98f00-05d6-4133-858e-d6fadc3d8655",
                    "@type": "psdiDcatExt:Guidance",
                    "dcterms:title": "User and Developer Guides for SimpNMR Software",
                    "rdfs:label": "User and Developer Guides for SimpNMR Software",
                    "dcterms:type": {
                        "skos:prefLabel": "Text",
                        "@type": "skos:Concept",
                        "@id": "http://purl.org/dc/dcmitype/Text"
                    },
                    "dcterms:description": "User guide for SimpNMR Python package (for the analysis of solution NMR data of paramagnetic metal complexes using computational chemistry methods). This user guide includes sections which cover 'Get Started' (installation instructions, workflows, and practical guidance for running prediction and fitting calculations with simpnmr), 'Tutorials' (downloadable example materials for the SimpNMR tutorials and workshop, provided as ready-to-use files from the repository), 'Developer Guide' (internal architecture, contribution guidelines, and maintenance notes for developers and advanced users) and 'Templates' (downloadable YAML templates for common prediction and fitting workflows).",
