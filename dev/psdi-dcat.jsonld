            {
                "@id": "psdiDcat:resource-theme/27774cac-6e13-4602-a547-ae5c68032a75",
                "dcterms:identifier": "https://resources.psdi.ac.uk/resource-theme/27774cac-6e13-4602-a547-ae5c68032a75",
                "@type": "dcat:Catalog",
                "dcterms:title": "Machine Learning for Next-Generation Transmission Electron Microscopy (TEM)",
                "rdfs:label": "Machine Learning for Next-Generation Transmission Electron Microscopy (TEM)",
                "dcterms:type": {
                    "skos:prefLabel": "Collection",
                    "@type": "skos:Concept",
                    "@id": "http://purl.org/dc/dcmitype/Collection"
                },
                "dcterms:description": "TEMPOS (Transmission Electron Microscopy Particle Outline Segmentation) is used to generate synthetic datasets and train segmentation models via transfer learning, which are subsequently applied to segment experimental images to identify particle size, shape and morphology, across a range of substrates. Both the experimental data and their synthetic training counterparts, along with the resulting segmentation outputs, are archived and made available through 'TEM-ParticlesDB', an open-source repository of Transmission Electron Microscopy (TEM) images.",
