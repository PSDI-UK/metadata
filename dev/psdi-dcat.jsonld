                "psdiDcatExt:displayPriority": 2.0,
                "dcat:DataService": {
                    "@id": "psdiDcat:service/32e801c3-7a81-488b-a15b-8f9240ea74b4",
                    "dcterms:identifier": "https://resources.psdi.ac.uk/service/32e801c3-7a81-488b-a15b-8f9240ea74b4",
                    "@type": "dcat:DataService",
                    "dcterms:title": "PXRD-conditioned CrystaLLM-pi Web Application (AI-driven Prediction of Crystal Structure)",
                    "rdfs:label": "PXRD-conditioned CrystaLLM-pi Web Application",
                    "dcterms:type": {
                        "skos:prefLabel": "Service",
                        "@type": "skos:Concept",
                        "@id": "http://purl.org/dc/dcmitype/Service"
                    },
                    "dcterms:description": "The CrystaLLM-pi web application provides an accessible, browser-based interface for generating crystalline structures using state-of-the-art generative AI. Users can quickly create candidate materials either from chemical composition alone or by combining composition with experimental X-ray diffraction (XRD) data.\nDesigned for ease of use, the webapp enables interactive exploration of crystal structures without requiring local installation or machine learning expertise. Generated structures are returned in standard CIF format, making them ready for visualisation or downstream simulation, and supporting rapid integration into experimental and computational materials workflows.",
                    "dcat:keyword": [
                        "PSDI-funding-call-FC1-A1-2025",
                        "materials discovery",
                        "crystal structure generation",
                        "generative machine learning",
                        "inverse materials design",
                        "crystallographic data"
                    ],
