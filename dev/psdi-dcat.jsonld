                "psdiDcatExt:logoURL": {
                    "rdfs:label": "BenchmarkSet1500 logo",
                    "@type": "rdfs:Resource",
                    "@id": "https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/organicSemiconductorBenchmarkDataset-r.svg"
                },
                "dcterms:bibliographicCitation": "Publication to be cited by Tahereh Nematiaram and Malin Zollner in review (details will shortly be updated here).",
                "psdiDcatExt:displayPriority": 2.0,
                "dcat:Dataset": {
                    "@id": "psdiDcat:data/49486e34-832f-4bc6-87b7-4a7b5acecd65",
                    "dcterms:identifier": "https://resources.psdi.ac.uk/data/49486e34-832f-4bc6-87b7-4a7b5acecd65",
                    "@type": "dcat:Dataset",
                    "dcterms:title": "BenchmarkSet1500: High-Accuracy Excited-State Reference Benchmark Dataset for Organic Semiconductors",
                    "rdfs:label": "BenchmarkSet1500",
                    "dcterms:type": {
                        "skos:prefLabel": "Dataset",
                        "@type": "skos:Concept",
                        "@id": "http://purl.org/dc/dcmitype/Dataset"
                    },
                    "dcterms:description": "BenchmarkSet1500 is an open-access multireference excited-state database established to provide the first dedicated high-accuracy benchmark set for organic semiconductor research. The repository comprises 1,500 small organic molecules with consistently computed vertical excited-state properties obtained using state-averaged complete active space self-consistent field (SA-CASSCF) and strongly contracted N-electron valence state second-order perturbation theory (SC-NEVPT2), alongside the full reproducible workflow code used to generate the dataset. The dataset focuses on systems where single-reference approaches (e.g. TD-DFT) are known to fail, including molecules exhibiting strong static correlation and inverted singlet-triplet gaps. BenchmarkSet1500 is designed to support rigorous method benchmarking, systematic assessment of theory-level performance, development of predictive models, and screening for technologically relevant organic semiconductors.",
                    "dcat:keyword": [
                        "PSDI-funding-call-FC1-2025",
                        "organic semiconductors",
                        "excited-state",
                        "multireference",
                        "time-dependent density functional theory",
                        "TD-DFT",
                        "complete active space self-consistent field",
                        "CASSCF",
                        "N-electron valence state second-order perturbation theory",
                        "NEVPT2",
                        "inverted singlet-triplet gap",
                        "INVEST",
                        "organic light-emitting diode",
                        "OLED",
                        "thermally activated delayed fluorescence",
                        "TADF",
                        "singlet-triplet gap"
                    ],
