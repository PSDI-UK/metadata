                "psdiDcatExt:logoURL": {
                    "rdfs:label": "Case Studies Resource Theme logo",
                    "@type": "rdfs:Resource",
                    "@id": "https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/caseStudies-r.svg"
                },
                "psdiDcatExt:displayPriority": 2.0,
                "psdiDcatExt:Guidance": [
                    {
                        "@id": "psdiDcat:guidance/0ce7f2d9-d187-4398-b113-947856712ec0",
                        "dcterms:identifier": "https://resources.psdi.ac.uk/guidance/0ce7f2d9-d187-4398-b113-947856712ec0",
                        "@type": "psdiDcatExt:Guidance",
                        "dcterms:title": "Resurrecting Second Harmonic Generation (SHG) Case Study",
                        "rdfs:label": "psdi_shg_exemplar",
                        "dcterms:type": {
                            "skos:prefLabel": "Text",
                            "@type": "skos:Concept",
                            "@id": "http://purl.org/dc/dcmitype/Text"
                        },
                        "dcterms:description": "The preservation, accessibility, and reuse of scientific data are increasingly vital in contemporary research. Historical datasets, often termed legacy data, provide significant opportunities for new discoveries, validation of past results, and insights through modern analytical methods. Despite their potential value, legacy datasets frequently suffer from poor documentation, outdated formats, and technological obsolescence, complicating their reuse. This report addresses these challenges through the reconstruction of databases originating from Second Harmonic Generation (SHG) experiments, conducted as part of a doctoral research project completed in 2011 at the University of Southampton.",
                        "dcat:keyword": [
                            "PSDI-pathfinder",
                            "second harmonic generation"
                        ],
                        "dcat:theme": [
                            {
                                "skos:prefLabel": "data processing",
                                "@type": "skos:Concept",
                                "@id": "http://data.europa.eu/8mn/euroscivoc/995f4448-d135-4ba0-925f-e7afa18a0d0e"
                            },
                            {
                                "skos:prefLabel": "nonlinear optics",
                                "@type": "skos:Concept",
                                "@id": "http://data.europa.eu/8mn/euroscivoc/5ccac6a4-396a-4789-9506-de4ee54aae3d"
                            }
                        ],
