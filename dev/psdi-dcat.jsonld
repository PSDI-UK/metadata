                "psdiDcatExt:logoURL": {
                    "rdfs:label": "CrystaLLM-pi logo",
                    "@type": "rdfs:Resource",
                    "@id": "https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/crystalLMpi-r.png"
