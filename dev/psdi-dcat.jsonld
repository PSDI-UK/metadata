            {
                "@id": "psdiDcat:resource-theme/1d0c399d-2fc8-4b10-abcd-cd17ef0bcb8d",
                "dcterms:identifier": "https://resources.psdi.ac.uk/resource-theme/1d0c399d-2fc8-4b10-abcd-cd17ef0bcb8d",
                "@type": "dcat:Catalog",
                "dcterms:title": "PSDI Data Revival",
                "rdfs:label": "PSDI Data Revival",
                "dcterms:type": {
                    "skos:prefLabel": "Collection",
                    "@type": "skos:Concept",
                    "@id": "http://purl.org/dc/dcmitype/Collection"
                },
                "dcterms:description": "The majority of laboratories and research groups have stacks of paper notebooks filled with valuable data that is difficult and time-consuming to access and use. Data Revival is an AI-driven service that can seamlessly convert your handwritten lab book pages into machine-readable data, unlocking the potential of your chemistry data. Operating with a high degree of accuracy, Data Revival creates relational links across your chemical data and enables users to run semantic searches across potentially millions of data points, including complex chemical structures. PSDI offers users the chance to experience Data Revival's capabilities firsthand.",
