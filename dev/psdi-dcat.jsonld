                },
                "dcterms:bibliographicCitation": "Please cite: Andrew Stewart and Natalia Da Silva De Sa. Machine Learning for Next-Generation Transmission Electron Microscopy (TEM). Online. Available from: https://resources.psdi.ac.uk/resource-theme/27774cac-6e13-4602-a547-ae5c68032a75. [accessed YYYY-MM-DD].",
                "psdiDcatExt:displayPriority": 2.0,
                "dcat:Dataset": {
                    "@id": "psdiDcat:data/1c588bd2-6c7d-4f74-8b61-426b7d864d3a",
                    "dcterms:identifier": "https://resources.psdi.ac.uk/data/1c588bd2-6c7d-4f74-8b61-426b7d864d3a",
                    "@type": "dcat:Dataset",
                    "dcterms:title": "TEM-ParticlesDB: Next-Generation Transmission Electron Microscopy (TEM) images",
                    "rdfs:label": "TEM-ParticlesDB",
                    "dcterms:type": {
                        "skos:prefLabel": "Dataset",
                        "@type": "skos:Concept",
                        "@id": "http://purl.org/dc/dcmitype/Dataset"
                    },
                    "dcterms:description": "TEM-ParticlesDB is an open repository of Transmission Electron Microscopy (TEM) nanoparticle images and associated segmentation data that have been automatically segmented using machine learning to identify particle size, shape and morphology across a range of substrates. Each entry includes the original experimental TEM images, the synthetic training data used to develop the segmentation models, and the resulting segmented particle outlines. The synthetic data is generated using the TEMPOS (Transmission Electron Microscopy Particle Outline Segmentation) software and used to train segmentation models via transfer learning, before being applied to the experimental images.",
