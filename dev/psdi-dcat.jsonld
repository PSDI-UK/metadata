                    {
                        "@id": "psdiDcat:data/optimade-cod-cod",
                        "dcterms:identifier": "https://resources.psdi.ac.uk/data/optimade-cod-cod",
                        "@type": "dcat:Dataset",
                        "dcterms:title": "Crystallography Open Database (PSDI Mirror)",
                        "rdfs:label": "PSDI COD",
                        "dcterms:type": {
                            "skos:prefLabel": "Dataset",
                            "@type": "skos:Concept",
                            "@id": "http://purl.org/dc/dcmitype/Dataset"
                        },
                        "dcterms:description": "The Crystallography Open Database (COD) is an open-access collection of crystal structures for organic, inorganic, metal-organic compounds and minerals, excluding biopolymers. It contains over half a million entries from a wide range of published and unpublished sources, including large databases, small collections, and individual contributors. All data are made available under a permissive open-access licence. This dataset was originally developed and is maintained by the Crystallography Open Database project at https://www.crystallography.net/cod/. PSDI provides a mirror of both the COD website and its corresponding OPTIMADE endpoint to offer a UK-based access point, improving availability, resilience and performance.",
                        "dcat:keyword": [
                            "OPTIMADE",
                            "API",
                            "database",
                            "COD",
                            "crystallography",
