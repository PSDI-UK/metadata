                "psdiDcatExt:displayPriority": 1.0,
                "dcat:Dataset": {
                    "@id": "psdiDcat:data/07d83ee6-bad9-4c23-abea-ac70745b0803",
                    "dcterms:identifier": "https://resources.psdi.ac.uk/data/07d83ee6-bad9-4c23-abea-ac70745b0803",
                    "@type": "dcat:Dataset",
                    "dcterms:title": "Cambridge Structural Database (CSD)",
                    "rdfs:label": "Cambridge Structural Database (CSD)",
                    "dcterms:type": {
                        "skos:prefLabel": "Dataset",
                        "@type": "skos:Concept",
                        "@id": "http://purl.org/dc/dcmitype/Dataset"
                    },
                    "dcterms:description": "The Cambridge Structural Database (CSD), maintained by the Cambridge Crystallographic Data Centre (CCDC), is the world's largest curated collection of experimentally determined crystal structures, containing more than 1.3 million accurate 3D structures derived from X ray, neutron, and electron diffraction analyses. It is widely used across research and industry including pharmaceuticals, agrochemicals, and fine chemicals, to support structure prediction, materials design, and data driven discovery. Within PSDI, access to the CSD is available to authenticated users from the UK academic community. Users can search the CSD through the Find a Substance option in the PSDI Cross Data Search service or via the dedicated webCSD interface. CSD software tools are also available through PSDI's Remote Desktop Access. Use the Visit or resource landing page link to search the CSD via PSDI Cross Data Search, and see Linked Resources for links to webCSD and CSD software. Find out more using the links in the Further Information section.",
