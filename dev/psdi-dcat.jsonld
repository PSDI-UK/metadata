                "psdiDcatExt:displayPriority": 1.0,
                "psdiDcatExt:Guidance": [
                    {
                        "@id": "psdiDcat:guidance/74f53465-3cf8-49ff-be58-f7a5b749a981",
                        "dcterms:identifier": "https://resources.psdi.ac.uk/guidance/74f53465-3cf8-49ff-be58-f7a5b749a981",
                        "@type": "psdiDcatExt:Guidance",
                        "dcterms:title": "Research Data Management Guidance",
                        "rdfs:label": "Research Data Management Guidance",
                        "dcterms:type": {
                            "skos:prefLabel": "Text",
                            "@type": "skos:Concept",
                            "@id": "http://purl.org/dc/dcmitype/Text"
                        },
                        "dcterms:description": "This collection of topics provides an introduction to research data management, including a discussion of different research data types, how to identify your own research data, and creating a data inventory. Guidance is provided on the different stages of the research data lifecycle and the benefits of data management planning, and the role of the Data Management Plan (DMP) together with an example DMP for physical scientists. This section also includes topics on best practices for managing data when working with others, and where you can get additional help with managing your research data.",
                        "dcat:keyword": [
