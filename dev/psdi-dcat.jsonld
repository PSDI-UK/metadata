                    {
                        "@id": "psdiDcat:data/6304dad5-8c21-4d05-aa38-349b641ffbf6",
                        "dcterms:identifier": "https://resources.psdi.ac.uk/data/6304dad5-8c21-4d05-aa38-349b641ffbf6",
                        "@type": "dcat:Dataset",
                        "dcterms:title": "Propersea (Property Prediction)",
                        "rdfs:label": "Propersea (Property Prediction)",
                        "dcterms:type": {
                            "skos:prefLabel": "Dataset",
                            "@type": "skos:Concept",
                            "@id": "http://purl.org/dc/dcmitype/Dataset"
                        },
                        "dcterms:description": "Propersea contains calculated predictions for a wide range of molecular and physicochemical properties for small molecules, such as melting and boiling points, density, solubility, polarizability, and more. It employs various algorithms, including RDKit, semi-empirical quantum methods, Bayesian regression trees, and transformer neural networks. Propersea also contains predicted IUPAC names generated using a machine learning model. Propersea can be searched using the PSDI Cross Data Search service using InChIs, SMILES or by drawing a molecule. Results include predicted values, confidence intervals and reliability scores for the prediction.",
                        "dcat:keyword": [
                            "molecule",
                            "predicted property",
                            "RDKit",
                            "melting point",
                            "boiling point",
                            "density",
                            "logP",
                            "solubility",
                            "polarizability",
                            "IUPAC name",
                            "PSDS",
                            "Physical Sciences Data-Science Service"
                        ],
