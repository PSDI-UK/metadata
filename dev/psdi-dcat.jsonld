                    {
                        "@id": "psdiDcat:data/06bdf98c-e51b-4656-a424-2c9e80b68c76",
                        "dcterms:identifier": "https://resources.psdi.ac.uk/data/06bdf98c-e51b-4656-a424-2c9e80b68c76",
                        "@type": "dcat:Dataset",
                        "dcterms:title": "Chemotion Repository",
                        "rdfs:label": "Chemotion Repository",
                        "dcterms:type": {
                            "skos:prefLabel": "Dataset",
                            "@type": "skos:Concept",
                            "@id": "http://purl.org/dc/dcmitype/Dataset"
                        },
                        "dcterms:description": "The Chemotion Repository is an open repository of well-structured and machine-readable chemical data created by the Karlsruhe Institute of Technology. The focus of the repository is synthetic and analytical chemistry data. It includes data pertaining to reactions, molecules and physical samples. Data in the repository is uploaded by the community, and is subject to peer review.",
