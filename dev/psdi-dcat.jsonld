                    {
                        "@id": "psdiDcat:tool/1839c691-c787-4d32-9fc3-e9c220902e93",
                        "dcterms:identifier": "https://resources.psdi.ac.uk/tool/1839c691-c787-4d32-9fc3-e9c220902e93",
                        "@type": "psdiDcatExt:Tool",
                        "dcterms:title": "DL_MONTE Container Image (SIF format)",
                        "rdfs:label": "DL_MONTE Container Image (SIF format)",
                        "dcterms:type": {
                            "skos:prefLabel": "Software",
                            "@type": "skos:Concept",
                            "@id": "http://purl.org/dc/dcmitype/Software"
                        },
                        "dcterms:description": "The DL_MONTE Container Image enables users to run the Monte Carlo molecular simulation program DL_MONTE on their own computing infrastructure using Singularity and Apptainer. The tool supports many Monte Carlo methods, including grand-canonical Monte Carlo and advanced free energy techniques such as Wang-Landau. The tool supports many types of interatomic interactions facilitating the modelling of a wide range of materials and fluids. The container enables users to run DL_MONTE simulations directly with input files, removing the need to manually compile a DL_MONTE binary from the source code.",
