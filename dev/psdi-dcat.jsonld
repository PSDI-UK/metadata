                    {
                        "@id": "psdiDcat:service/43f76f68-abd1-4fa4-802a-1d76ec2e1358",
                        "dcterms:identifier": "https://resources.psdi.ac.uk/service/43f76f68-abd1-4fa4-802a-1d76ec2e1358",
                        "@type": "dcat:DataService",
                        "dcterms:title": "Web Access to DETHERM (Thermophysical Property Data)",
                        "rdfs:label": "Web Access to DETHERM",
                        "dcterms:type": {
                            "skos:prefLabel": "Service",
                            "@type": "skos:Concept",
                            "@id": "http://purl.org/dc/dcmitype/Service"
                        },
                        "dcterms:description": "DETHERM, developed and maintained by DECHEMA, is one of the world's largest collections of thermophysical property data. It brings together more than 13 million datasets covering over 100,000 pure compounds and 200,000 mixtures. The database includes a wide range of experimentally measured and evaluated properties - such as phase equilibrium data, vapour pressures, thermodynamic and transport properties, surface tensions, and electrolyte behaviour - along with associated bibliographic information, descriptors, and abstracts. The resource integrates data from several established collections, including DDB (Dortmunder Datenbank), ELDAR (Electrolyte Data Collection), INFOTHERM (Thermophysical Database), COMDOR (Thermophysical Parameter Database), C-DATA (Data Collection), BDBB (Basic Database Bohlen), CAPEC-SDB (Solubility Database), and additional DECHEMA datasets. Access to DETHERM through PSDI is available to authenticated users within the UK academic community through its dedicated web portal, where searches can be refined by phase, temperature, pressure, and number of components. Note that users must be attached to an academic network to access DETHERM data.",
                        "dcat:keyword": [
                            "thermodynamic properties",
                            "transport properties",
                            "phase equilibrium",
                            "vapor pressure",
                            "critical point",
                            "surface tension",
                            "electrolyte",
                            "pure substance",
                            "mixture",
                            "thermophysical properties",
                            "solubility",
                            "excess properties",
                            "PSDS",
                            "Physical Sciences Data-Science Service"
                        ],
