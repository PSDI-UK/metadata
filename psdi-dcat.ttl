<http://metadata.psdi.ac.uk/psdi-dcat/service/43f76f68-abd1-4fa4-802a-1d76ec2e1358> a dcat:DataService ;
    rdfs:label "Web Access to DETHERM"^^xsd:string ;
    psdiDcatExt:displayPriority 1e+00 ;
    psdiDcatExt:furtherInformation <https://dechema.de/en/detherm.html>,
        <https://guidance.psdi.ac.uk/docusaurus-pages/docs/guidance/psdi-resources/data-sources/subscribed/detherm> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/psdiSubscribedResources-s-detherm.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_16ec> ;
    dcterms:bibliographicCitation "U. Westhaus, T. Droge, R. Sass, DETHERM-a thermophysical property database, Fluid Phase Equilibria, Volumes 158-160, 1999, Pages 429-435, ISSN 0378-3812, https://doi.org/10.1016/S0378-3812(99)00139-9."^^xsd:string ;
    dcterms:creator <http://www.ddbst.com/>,
        <https://ror.org/000gm1k91/>,
        <https://ror.org/01eezs655/>,
        <https://ror.org/01hsw0492/>,
        <https://ror.org/049px0x49/>,
        <https://ror.org/04qtj9h94/>,
        <https://ror.org/05ggn0a85/> ;
    dcterms:description "DETHERM, developed and maintained by DECHEMA, is one of the world's largest collections of thermophysical property data. It brings together more than 13 million datasets covering over 100,000 pure compounds and 200,000 mixtures. The database includes a wide range of experimentally measured and evaluated properties - such as phase equilibrium data, vapour pressures, thermodynamic and transport properties, surface tensions, and electrolyte behaviour - along with associated bibliographic information, descriptors, and abstracts. The resource integrates data from several established collections, including the Dortmunder Datenbank (DDB), ELDAR, INFOTHERM, COMDOR, C DATA, BDBB, CAPEC SDB, and additional DECHEMA datasets. Access to DETHERM through PSDI is available to authenticated users within the UK academic community through its dedicated web portal, where searches can be refined by phase, temperature, pressure, and number of components. Note that users must be attached to an academic network to search DETHERM and download data."^^xsd:string ;
    dcterms:identifier "psdiDcat:service/43f76f68-abd1-4fa4-802a-1d76ec2e1358"^^xsd:string ;
    dcterms:issued "1999-01-03T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://dechema.de/en/impressum.html> ;
    dcterms:modified "2025-07-01T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:publisher <https://ror.org/01hsw0492/> ;
    dcterms:title "Web Access to DETHERM (Thermophysical Property Data)"^^xsd:string ;
    dcterms:type dcmitype:Service ;
