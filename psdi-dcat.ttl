<http://metadata.psdi.ac.uk/psdi-dcat/guidance/74f53465-3cf8-49ff-be58-f7a5b749a981> a psdiDcatExt:Guidance ;
    rdfs:label "Research Data Management Guidance"^^xsd:string ;
    psdiDcatExt:displayPriority 1e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/knowledgeBaseTopics-r.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Cerys Willoughby and Louise Saul. Research Data Management Guidance. Online. Physical Sciences Data Infrastructure (PSDI), 01 January 2025. Available from: https://resources.psdi.ac.uk/guidance/74f53465-3cf8-49ff-be58-f7a5b749a981. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0003-1721-9212>,
        <http://orcid.org/0009-0000-6422-0342> ;
    dcterms:description "This collection of topics provides an introduction to research data management, including a discussion of different research data types, how to identify your own research data, and creating a data inventory. Guidance is provided on the different stages of the research data lifecycle and the benefits of data management planning, and the role of the Data Management Plan (DMP) together with an example DMP for physical scientists. This section also includes topics on best practices for managing data when working with others, and where you can get additional help with managing your research data."^^xsd:string ;
    dcterms:identifier "psdiDcat:guidance/74f53465-3cf8-49ff-be58-f7a5b749a981"^^xsd:string ;
    dcterms:issued "2025-01-01T00:00:00+00:00"^^xsd:dateTime ;
