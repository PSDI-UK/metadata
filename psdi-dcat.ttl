<http://metadata.psdi.ac.uk/psdi-dcat/guidance/5cd98f00-05d6-4133-858e-d6fadc3d8655> a psdiDcatExt:Guidance ;
    rdfs:label "User and Developer Guides for SimpNMR Software"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:furtherInformation <https://chemrxiv.org/doi/full/10.26434/chemrxiv.15001463/v1> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/simpNMR-r.png> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Elizaveta Suturina, Jon G. C. Kragskow, James W. Whipham and Ernest Borysenko. User and Developer Guides for SimpNMR Software. Online. 08 February 2026. Available from: https://resources.psdi.ac.uk/guidance/5cd98f00-05d6-4133-858e-d6fadc3d8655. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <https://orcid.org/0000-0001-8283-2959>,
        <https://orcid.org/0000-0001-9488-8204>,
        <https://orcid.org/0000-0003-4407-1882>,
        <https://www.linkedin.com/in/ernestborysenko> ;
    dcterms:description "User guide for SimpNMR Python package (for the analysis of solution NMR data of paramagnetic metal complexes using computational chemistry methods). This user guide includes sections which cover 'Get Started' (installation instructions, workflows, and practical guidance for running prediction and fitting calculations with simpnmr), 'Tutorials' (downloadable example materials for the SimpNMR tutorials and workshop, provided as ready-to-use files from the repository), 'Developer Guide' (internal architecture, contribution guidelines, and maintenance notes for developers and advanced users) and 'Templates' (downloadable YAML templates for common prediction and fitting workflows)."^^xsd:string ;
    dcterms:identifier "psdiDcat:guidance/5cd98f00-05d6-4133-858e-d6fadc3d8655"^^xsd:string ;
