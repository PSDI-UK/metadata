<http://metadata.psdi.ac.uk/psdi-dcat/tool/6bcaa538-a26f-4720-a505-bada3aa52f55> a psdiDcatExt:Tool ;
    rdfs:label "janus-core, Machine Learning Interatomic Potentials (MLIP) Tool"^^xsd:string ;
    psdiDcatExt:developmentStatus "Development Status :: 3 - Alpha"^^xsd:string ;
    psdiDcatExt:displayPriority 2.1e+00 ;
    psdiDcatExt:furtherInformation <https://github.com/stfc/janus-core/blob/main/README.md> ;
