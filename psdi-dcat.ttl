<http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/27774cac-6e13-4602-a547-ae5c68032a75> a dcat:Catalog ;
    rdfs:label "Machine Learning for Next-Generation Transmission Electron Microscopy (TEM)"^^xsd:string ;
    psdiDcatExt:Guidance <http://metadata.psdi.ac.uk/psdi-dcat/guidance/97557d0d-af8e-4ce2-97f4-f943e21e3925> ;
    psdiDcatExt:Tool <http://metadata.psdi.ac.uk/psdi-dcat/tool/323cc7d7-4538-47ca-bdd3-ab02194b7834> ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/tempos-r.png> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Andrew Stewart and Natalia Da Silva De Sa. Machine Learning for Next-Generation Transmission Electron Microscopy (TEM). Online. Available from: https://resources.psdi.ac.uk/resource-theme/27774cac-6e13-4602-a547-ae5c68032a75. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <https://orcid.org/0000-0002-3081-5644>,
        <https://orcid.org/0009-0005-2972-9975> ;
    dcterms:description "TEMPOS (Transmission Electron Microscopy Particle Outline Segmentation) is used to generate synthetic datasets and train segmentation models via transfer learning, which are subsequently applied to segment experimental images to identify particle size, shape and morphology, across a range of substrates. Both the experimental data and their synthetic training counterparts, along with the resulting segmentation outputs, are archived and made available through 'TEM-ParticlesDB', an open-source repository of Transmission Electron Microscopy (TEM) images."^^xsd:string ;
    dcterms:identifier "psdiDcat:resource-theme/27774cac-6e13-4602-a547-ae5c68032a75"^^xsd:string ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "Machine Learning for Next-Generation Transmission Electron Microscopy (TEM)"^^xsd:string ;
    dcterms:type dcmitype:Collection ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:Dataset <http://metadata.psdi.ac.uk/psdi-dcat/data/1c588bd2-6c7d-4f74-8b61-426b7d864d3a> ;
    dcat:contactPoint <mailto:support@psdi.ac.uk/> ;
    dcat:keyword "AI ready dataset"^^xsd:string,
        "TEM"^^xsd:string,
        "Transmission Electron Microscopy"^^xsd:string,
        "experimental"^^xsd:string,
        "nanoparticles"^^xsd:string,
        "segmentation"^^xsd:string,
        "segmented"^^xsd:string,
        "synthetic"^^xsd:string ;
    dcat:qualifiedRelation [ a dcat:Relationship ;
            dcterms:relation <http://metadata.psdi.ac.uk/psdi-dcat/guidance/97557d0d-af8e-4ce2-97f4-f943e21e3925> ;
            dcat:hadRole <http://www.iana.org/assignments/relation/describedby> ] ;
    dcat:theme <http://data.europa.eu/8mn/euroscivoc/81c628f1-5365-4517-ae99-a6bdcc65ba24>,
        <http://data.europa.eu/8mn/euroscivoc/9f2d4860-d6ab-446c-bad7-a6e7e4801cf1> .

