        <http://orcid.org/0009-0009-9897-333X>,
        <http://www.linkedin.com/in/jack-doyle-175183323> ;
    dcterms:description "This resource presents data exemplars and detailed case study reports from our investigations into unlocking the potential of legacy data. It highlights our approaches to meaningfully revive outdated datasets, enhancing their quality, and maximising their value. These efforts aim to provide practical guidance on methods for resurrecting data, uncovering value in hidden data sources, and accelerating scientific progress."^^xsd:string ;
    dcterms:identifier "psdiDcat:resource-theme/61577a4d-ced8-4ebd-9443-88a54b74de1a"^^xsd:string ;
    dcterms:issued "2025-04-24T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/CC-BY-4.0.html> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "Case Studies: Discovering Value in Legacy Data"^^xsd:string ;
    dcterms:type dcmitype:Collection ;
    adms:status <http://purl.org/adms/status/Completed> ;
    dcat:contactPoint <mailto:support@psdi.ac.uk/> ;
