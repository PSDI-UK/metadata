    dcat:theme <http://metadata.psdi.ac.uk/psdi-voc-subject#multidisciplinary> .

<http://metadata.psdi.ac.uk/psdi-dcat/service/fc2fbf02-8638-414b-acb9-a16ea44dfff0> a dcat:DataService ;
    rdfs:label "CDI portal"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/catalysisDataInfrastructure-r.png> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Abraham Nieva De La Hidalga. Catalysis Data Infrastructure (CDI) Portal. Online. Version 0.9. 12 April 2021. Available from: https://resources.psdi.ac.uk/service/fc2fbf02-8638-414b-acb9-a16ea44dfff0. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0001-7348-7612> ;
    dcterms:description "The deployed Thematic Portal for the UK Catalysis Hub (CDI) offers summary reports on publications and research impact within this important scientific domain. It provides insights into publications, authors, institutions, top researchers, countries, and themes, while tracking changes over time to identify research trends. This use case illustrates how thematic portals can showcase research productivity, emphasize emerging trends, and simplify access to supporting data."^^xsd:string ;
    dcterms:identifier "psdiDcat:service/fc2fbf02-8638-414b-acb9-a16ea44dfff0"^^xsd:string ;
    dcterms:issued "2021-04-12T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
