<http://metadata.psdi.ac.uk/psdi-dcat/guidance/f8c98217-7299-44f5-9a35-dac6c32ec52e> a psdiDcatExt:Guidance ;
    rdfs:label "Mini-Tutorials for XAFS RO-Crate Workflows in Galaxy"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/galaxy-r.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Abraham Nieva De La Hidalga. Mini-Tutorials for XAFS RO-Crate Workflows in Galaxy. Online. Version 0.5. 28 October 2024. Available from: https://resources.psdi.ac.uk/guidance/f8c98217-7299-44f5-9a35-dac6c32ec52e. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0001-7348-7612> ;
    dcterms:description "The Mini-Tutorials for XAFS RO-Crate Workflows in Galaxy provide a brief introduction to working with RO-Crates in Galaxy. The development of the tutorials originated as quickstart guidance for running and inspecting workflows used for the reproduction of X-ray absorption fine structure (XAFS) analyses. These self-paced learning resources cover three aspects of the RO-Crate lifecycle in the Galaxy platform: Importing (and running) a workflow, Creation (Exporting) an RO-Crate and Importing (and inspecting) an RO-Crate."^^xsd:string ;
    dcterms:identifier "psdiDcat:guidance/f8c98217-7299-44f5-9a35-dac6c32ec52e"^^xsd:string ;
    dcterms:issued "2024-10-28T00:00:00+00:00"^^xsd:dateTime ;
