<http://metadata.psdi.ac.uk/psdi-dcat/tool/1839c691-c787-4d32-9fc3-e9c220902e93> a psdiDcatExt:Tool ;
    rdfs:label "DL_MONTE Container Image (SIF format)"^^xsd:string ;
    psdiDcatExt:deliveryFormat <https://www.iana.org/assignments/media-types/application/vnd.oci.image.manifest.v1+json> ;
    psdiDcatExt:developmentStatus "Development Status :: 3 - Alpha"^^xsd:string ;
    psdiDcatExt:displayPriority 3e+00 ;
    psdiDcatExt:downloadURL <https://ghcr.io/psdi-uk/dlmonte-container/dlmonte-sif> ;
    psdiDcatExt:furtherInformation <https://github.com/PSDI-UK/dlmonte-container/blob/main/README.md> ;
    psdiDcatExt:installCommand "apptainer pull oras://ghcr.io/psdi-uk/dlmonte-container/dlmonte-sif:latest"^^xsd:string ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/containerImageRegistry-r.svg> ;
    psdiDcatExt:programmingLanguage "Programming Language :: Fortran; Programming Language :: Unix Shell"^^xsd:string ;
    psdiDcatExt:repositoryURL <https://github.com/PSDI-UK/dlmonte-container> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Tom Underwood. DL_MONTE Container Image (SIF format). Online. Version 0.0.7. 27 October 2024. Available from: https://resources.psdi.ac.uk/tool/1839c691-c787-4d32-9fc3-e9c220902e93. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0001-6431-0612> ;
    dcterms:description "The DL_MONTE Container Image enables users to run the Monte Carlo molecular simulation program DL_MONTE on their own computing infrastructure using Singularity and Apptainer. The tool supports many Monte Carlo methods, including grand-canonical Monte Carlo and advanced free energy techniques such as Wang-Landau. The tool supports many types of interatomic interactions facilitating the modelling of a wide range of materials and fluids. The container enables users to run DL_MONTE simulations directly with input files, removing the need to manually compile a DL_MONTE binary from the source code."^^xsd:string ;
    dcterms:identifier "psdiDcat:tool/1839c691-c787-4d32-9fc3-e9c220902e93"^^xsd:string ;
    dcterms:issued "2024-10-27T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/>,
        <https://spdx.org/licenses/0BSD.html> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "DL_MONTE Container Image (SIF format)"^^xsd:string ;
    dcterms:type dcmitype:Software ;
