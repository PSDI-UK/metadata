    dcat:version "2.4.0"^^xsd:string .

<http://metadata.psdi.ac.uk/psdi-dcat/tool/f85c7c18-28b4-4efb-8edd-33d472683905> a psdiDcatExt:Tool ;
    rdfs:label "DSync (Data Transfer and Synchronisation) Container (SIF format)"^^xsd:string ;
    psdiDcatExt:deliveryFormat <https://www.iana.org/assignments/media-types/application/vnd.docker.distribution.manifest.v2+json> ;
    psdiDcatExt:developmentStatus "Development Status :: 3 - Alpha"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:downloadURL <https://ghcr.io/psdi-uk/data-transfer-container/data-transfer-sif> ;
    psdiDcatExt:furtherInformation <https://github.com/PSDI-UK/data-transfer-container/blob/main/README.md> ;
    psdiDcatExt:installCommand "apptainer pull oras://ghcr.io/psdi-uk/data-transfer-container/data-transfer-sif:latest"^^xsd:string ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/containerImageRegistry-r.svg> ;
    psdiDcatExt:programmingLanguage "Programming Language :: Unix Shell"^^xsd:string ;
    psdiDcatExt:repositoryURL <https://github.com/PSDI-UK/data-transfer-container> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Amali Pawula Hewage and Tom Underwood. DSync (Data Transfer and Synchronisation) Container (SIF format). Online. Version 0.0.11. Physical Sciences Data Infrastructure (PSDI), 05 January 2025. Available from: https://resources.psdi.ac.uk/tool/f85c7c18-28b4-4efb-8edd-33d472683905. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0001-6431-0612>,
        <http://www.linkedin.com/in/amali-shashiprabha-rajapaksha> ;
    dcterms:description "Transferring data is crucial for researchers to share information with colleagues and back up their work. However, setting up specialized software for this can be challenging. The Data Transfer and Synchronisation (DSync) tool simplifies this process by bundling the necessary software for transferring data to and from S3 storage - commonly used in cloud computing - into a single container image which can be run using Apptainer and Singularity. This makes it easier for researchers to manage data transfers without having to install and configure the software themselves."^^xsd:string ;
    dcterms:identifier "psdiDcat:tool/f85c7c18-28b4-4efb-8edd-33d472683905"^^xsd:string ;
    dcterms:issued "2025-01-05T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/>,
        <https://spdx.org/licenses/0BSD.html> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "DSync (Data Transfer and Synchronisation) Container (SIF format)"^^xsd:string ;
    dcterms:type dcmitype:Software ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
