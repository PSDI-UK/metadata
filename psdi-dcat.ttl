<http://metadata.psdi.ac.uk/psdi-dcat/guidance/cdbcfbaf-90fc-4336-a7bd-ecc8ed8baaf4> a psdiDcatExt:Guidance ;
    rdfs:label "CAMML"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/mlip-r.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_16ec> ;
    dcterms:bibliographicCitation "Please cite: Alin Marin Elena, Keith Butler, Reinhard Maurer, Alex Ganose, Ioan-Bogdan Magdău, Chris Mellor and Nicola Knight. Chemistry and Materials Machine Learning School (CAMML). Online. Available from: https://resources.psdi.ac.uk/guidance/cdbcfbaf-90fc-4336-a7bd-ecc8ed8baaf4. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0001-5432-5597>,
        <http://orcid.org/0000-0001-8286-3835>,
        <http://orcid.org/0000-0002-3004-785X>,
        <http://orcid.org/0000-0002-3963-5076>,
        <http://orcid.org/0000-0002-4486-3321>,
        <http://orcid.org/0000-0002-7013-6670>,
        <http://www.linkedin.com/in/christina-mellor-78568374> ;
    dcterms:description "Training is at the core of this resource theme. The Chemistry and Materials Machine Learning (CaMML) school is run by PSDI in collaboration with a range of communities. Training is targeted towards PhD students, in particular those in the Materials and Molecular Simulations field, who have experience of coding but are not highly experienced with machine learning. The aim of this in-person training is to introduce attendees to the latest methods of machine learning for the atomistic simulation of materials."^^xsd:string ;
    dcterms:identifier "psdiDcat:guidance/cdbcfbaf-90fc-4336-a7bd-ecc8ed8baaf4"^^xsd:string ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "Chemistry and Materials Machine Learning School (CAMML)"^^xsd:string ;
    dcterms:type dcmitype:Text ;
    dcat:contactPoint <mailto:support@psdi.ac.uk/> ;
    dcat:inCatalog <http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/aa3bd192-f865-45fd-9d0b-b6a9d6071992> ;
    dcat:keyword "materials simulations"^^xsd:string,
        "molecular simulations"^^xsd:string ;
