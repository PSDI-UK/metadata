<http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/3e2af553-056d-4c3c-be77-ef13a90c286a> a dcat:Catalog ;
    rdfs:label "TopoStats and AFMDB: Resources for Atomic Force Microscopy (AFM) Image Analysis"^^xsd:string ;
    psdiDcatExt:Tool <http://metadata.psdi.ac.uk/psdi-dcat/tool/e03c049a-fac0-4c00-8f71-a61f45d22d4d> ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:furtherInformation <https://afm-spm.github.io/TopoStats/latest/>,
        <https://data-collections.psdi.ac.uk/communities/afmdb/about> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/topostats-r.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:creator <https://orcid.org/0000-0002-2658-8987>,
        <https://orcid.org/0000-0002-8919-2701>,
        <https://orcid.org/0009-0008-9164-9513> ;
    dcterms:description "This resource theme contains AFM (Atomic Force Microscopy) resources that bring together tools and data collections to support the processing, analysis, and sharing of AFM datasets. The TopoStats tool enables the batch processing of AFM datafiles to obtain rich, quantitative statistics and is developed with the FAIR principles for research software in mind. The accompanying Community Data Collection, AFMDB, provides a platform for the sharing of AFM datafiles, along with processed images, to encourage open data practices and aid the devlopment of deep learning tools for enhanced AFM analysis."^^xsd:string ;
    dcterms:identifier "psdiDcat:resource-theme/3e2af553-056d-4c3c-be77-ef13a90c286a"^^xsd:string ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/>,
        <https://spdx.org/licenses/GPL-3.0-only.html>,
        <https://spdx.org/licenses/LGPL-3.0-only.html> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "TopoStats and AFMDB: Resources for Atomic Force Microscopy (AFM) Image Analysis"^^xsd:string ;
    dcterms:type dcmitype:Collection ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:Dataset <http://metadata.psdi.ac.uk/psdi-dcat/data/b21d01f6-20df-49da-a19a-88f7b42fbd11> ;
    dcat:contactPoint <mailto:support@psdi.ac.uk/> ;
    dcat:keyword "AFM"^^xsd:string,
        "Atomic Force Microscopy"^^xsd:string,
