        "density"^^xsd:string,
        "logP"^^xsd:string,
        "melting point"^^xsd:string,
        "molecule"^^xsd:string,
        "polarizability"^^xsd:string,
        "predicted property"^^xsd:string,
        "solubility"^^xsd:string ;
