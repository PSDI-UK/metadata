<http://metadata.psdi.ac.uk/psdi-dcat/service/32e801c3-7a81-488b-a15b-8f9240ea74b4> a dcat:DataService ;
    rdfs:label "PXRD-conditioned CrystaLLM-pi Web Application"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:furtherInformation <https://crystallm-pi.psdi.ac.uk/usage> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/crystalLMpi-r.png> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Keith Butler, Bradley A. A. Martin, Cyprien Bone and Ricardo Grau-Crespo. PXRD-conditioned CrystaLLM-pi Web Application (AI-driven Prediction of Crystal Structure). Online. 12 March 2026. Available from: https://resources.psdi.ac.uk/service/32e801c3-7a81-488b-a15b-8f9240ea74b4. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <https://orcid.org/0000-0001-5432-5597>,
        <https://orcid.org/0000-0001-8845-1719>,
        <https://orcid.org/0000-0003-1583-254X>,
        <https://orcid.org/0009-0002-7801-5272> ;
    dcterms:description """The CrystaLLM-pi web application provides an accessible, browser-based interface for generating crystalline structures using state-of-the-art generative AI. Users can quickly create candidate materials either from chemical composition alone or by combining composition with experimental X-ray diffraction (XRD) data.
Designed for ease of use, the webapp enables interactive exploration of crystal structures without requiring local installation or machine learning expertise. Generated structures are returned in standard CIF format, making them ready for visualisation or downstream simulation, and supporting rapid integration into experimental and computational materials workflows."""^^xsd:string ;
    dcterms:identifier "psdiDcat:service/32e801c3-7a81-488b-a15b-8f9240ea74b4"^^xsd:string ;
    dcterms:issued "2026-03-12T12:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:modified "2026-04-01T12:00:00+00:00"^^xsd:dateTime ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "PXRD-conditioned CrystaLLM-pi Web Application (AI-driven Prediction of Crystal Structure)"^^xsd:string ;
    dcterms:type dcmitype:Service ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
