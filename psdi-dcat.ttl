<http://metadata.psdi.ac.uk/psdi-dcat/tool/3961b931-e0e5-4a0c-a65d-083b68d4f142> a psdiDcatExt:Tool ;
    rdfs:label "SimpNMR"^^xsd:string ;
    psdiDcatExt:developmentStatus "Development Status :: 4 - Beta"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:furtherInformation <https://chemrxiv.org/doi/full/10.26434/chemrxiv.15001463/v1> ;
    psdiDcatExt:installCommand "pip install simpnmr"^^xsd:string ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/simpNMR-r.png> ;
    psdiDcatExt:operatingSystem "Operating System :: OS Independent"^^xsd:string ;
    psdiDcatExt:programmingLanguage "Programming Language :: Python :: 3"^^xsd:string ;
    psdiDcatExt:repositoryURL <https://gitlab.com/suturina-group/simpnmr> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "If you use SimpNMR in academic work, please cite the software and the specific version used. A DOI record will be added in the future."^^xsd:string ;
    dcterms:creator <https://orcid.org/0000-0001-8283-2959>,
        <https://orcid.org/0000-0001-9488-8204>,
        <https://orcid.org/0000-0003-4407-1882>,
        <https://www.linkedin.com/in/ernestborysenko> ;
    dcterms:description "SimpNMR is a Python package that simplifies analysis of the NMR spectra (e.g. 1H, 13C) of paramagnetic metal complexes in solution by incorporating outputs of ab initio calculations. It allows for prediction of the 1D spectra, assignment of experimental peaks, and fitting of the magnetic susceptibility tensor and the correlation times to experimental pNMR data. With variable temperature experiments, SimpNMR can also extract complete g-tensor in the molecular frame and in certain cases even D-tensor from solution pNMR data."^^xsd:string ;
    dcterms:identifier "psdiDcat:tool/3961b931-e0e5-4a0c-a65d-083b68d4f142"^^xsd:string ;
    dcterms:issued "2024-10-22T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/GPL-3.0-only.html> ;
    dcterms:modified "2026-03-10T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "SimpNMR (Software for Ab Initio-assisted Analysis of pNMR Data)"^^xsd:string ;
    dcterms:type dcmitype:Software ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:contactPoint <mailto:support@psdi.ac.uk/> ;
    dcat:inCatalog <http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/bb0f915a-8c4d-4d4c-a4ab-aade7f0ecbf4> ;
    dcat:keyword "DFT"^^xsd:string,
        "Density Functional Theory"^^xsd:string,
        "NMR spectra"^^xsd:string,
        "magnetic susceptibility"^^xsd:string,
        "pNMR"^^xsd:string,
        "paramanetic NMR"^^xsd:string ;
    dcat:landingPage <https://pypi.org/project/simpnmr> ;
    dcat:qualifiedRelation [ a dcat:Relationship ;
            dcterms:relation <http://metadata.psdi.ac.uk/psdi-dcat/guidance/5cd98f00-05d6-4133-858e-d6fadc3d8655> ;
            dcat:hadRole <http://www.iana.org/assignments/relation/describedby> ] ;
    dcat:theme <http://data.europa.eu/8mn/euroscivoc/4b85aedb-f755-4e39-9c09-e387cc6ce3e1>,
