<http://metadata.psdi.ac.uk/psdi-dcat/tool/1a4047ca-1994-4fcc-876f-abd9ab43d937> a psdiDcatExt:Tool ;
    rdfs:label "ML-PEG (Machine Learning Performance and Extrapolation Guide) Github Repository"^^xsd:string ;
    psdiDcatExt:displayPriority 2.5e+00 ;
    psdiDcatExt:furtherInformation <https://github.com/ddmms/ml-peg/blob/main/README.md> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/mlip-r.svg> ;
    psdiDcatExt:repositoryURL <https://github.com/ddmms/ml-peg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Elliott Kasoar, Joseph Hart, Ilyes Batatia, Gábor Csányi and Alin Marin Elena. ML-PEG (Machine Learning Performance and Extrapolation Guide) Github Repository. Online. Version 0.3.1. 03 April 2025. Available from: https://resources.psdi.ac.uk/tool/1a4047ca-1994-4fcc-876f-abd9ab43d937. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0002-7013-6670>,
        <http://orcid.org/0000-0002-8180-2034>,
        <http://orcid.org/0009-0005-0461-1436>,
        <http://orcid.org/0009-0005-2015-9478>,
        <https://orcid.org/0000-0001-6915-9851> ;
    dcterms:description "Repository to locally host a ML-PEG (Machine Learning Performance Guide) application as an interactive dashboard. ML-PEG is a comprehensive benchmarking framework and interactive performance guide for evaluating Machine Learning Interatomic Potentials (MLIPs) across diverse systems and properties beyond only energies and forces. The interactive performance guide, allowing users to explore and compare MLIP performance and deep dive into errors, connecting performance (or the lack of) to the underlying chemistry and physics. Please note that this code is currently available as an alpha release which is still under development."^^xsd:string ;
    dcterms:identifier "psdiDcat:tool/1a4047ca-1994-4fcc-876f-abd9ab43d937"^^xsd:string ;
    dcterms:issued "2025-04-03T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/GPL-3.0-only.html> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "ML-PEG (Machine Learning Performance and Extrapolation Guide) Github Repository"^^xsd:string ;
