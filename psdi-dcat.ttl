<http://metadata.psdi.ac.uk/psdi-dcat/service/d520fdb5-ebae-4746-80dd-59c5231cee11> a dcat:DataService ;
    rdfs:label "ELN Finder"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:furtherInformation <https://eln-finder.ulb.tu-darmstadt.de/info/page/about> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/digitalLabNotebooks-s-elnFinder.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Samantha Pearman-Kanza, Jeremy G. Frey, Cerys Willoughby, Donald Cruickshank and Louise Saul. ELN Finder. Online. 10 February 2023. Available from: https://resources.psdi.ac.uk/service/d520fdb5-ebae-4746-80dd-59c5231cee11. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0002-0777-0855>,
        <http://orcid.org/0000-0002-4831-9489>,
        <http://orcid.org/0000-0003-0842-4302>,
        <http://orcid.org/0000-0003-1721-9212>,
        <http://orcid.org/0009-0000-6422-0342> ;
    dcterms:description "ELNFinder, a resource actively supported by PSDI, assists researchers and staff from research institutions to select the most suitable Electronic Lab Notebook (ELN) software for their needs. Users can easily filter the extensive list of ELNs by key criteria such as import/export capabilities, search functionality, delivery model, data storage, and pricing options. The filters are grouped into useful categories: General, Usability, Core Functions (used for daily work), Extended Functions (used for daily work), Compliance with Legal Requirements, and Integration into Research Data Management (RDM) and IT environments. Users can use these filters to generate a list of ELNs that match their specific requirements."^^xsd:string ;
    dcterms:identifier "psdiDcat:service/d520fdb5-ebae-4746-80dd-59c5231cee11"^^xsd:string ;
    dcterms:issued "2023-02-10T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "ELN Finder"^^xsd:string ;
    dcterms:type dcmitype:Service ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:contactPoint <mailto:support@psdi.ac.uk/> ;
    dcat:endpointURL <https://eln-finder.ulb.tu-darmstadt.de/home> ;
