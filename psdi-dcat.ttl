<http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/89226c44-9d53-4952-99ec-0db48da3c58b> a dcat:Catalog ;
    rdfs:label "Project M: Calcium Carbonate Diffraction Datasets With Fit and Parameter Data"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:furtherInformation <https://data-collections.psdi.ac.uk/communities/project-m/about>,
        <https://doi.org/10.1039/D3CE01173A>,
        <https://doi.org/10.3389/fcomm.2023.1229616> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/projectM-r.png> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Claire Murray, Julia Parker and Tobias Bird. Project M: Calcium Carbonate Diffraction Datasets With Fit and Parameter Data. Online. Version 1.0.0. 19 March 2026. Available from: https://resources.psdi.ac.uk/resource-theme/89226c44-9d53-4952-99ec-0db48da3c58b. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <https://orcid.org/0000-0001-9929-726X>,
        <https://orcid.org/0000-0002-2514-5762>,
        <https://orcid.org/0000-0002-8306-3634> ;
    dcterms:description "Project M (https://www.diamond.ac.uk/ProjectM/) was a citizen science initiative run with UK secondary schools that generated an open collection of more than 650 calcium carbonate diffraction datasets, crystallised under a wide range of additives and conditions, with all associated fits and parameters included. This dataset forms part of the PSDI 'AI for Science' sub project ('Provision of 'AI ready' data: prototyping data pipelines and repositories', grant APP84520, award UKRI2697, opportunity OPP1033: EPSRC AI for Science) and has been selected and prepared as an example of AI ready data suitable for training AI tools and systems."^^xsd:string ;
    dcterms:identifier "psdiDcat:resource-theme/89226c44-9d53-4952-99ec-0db48da3c58b"^^xsd:string ;
    dcterms:issued "2026-03-19T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/CC-BY-4.0.html> ;
    dcterms:modified "2026-03-19T00:00:00+00:00"^^xsd:dateTime ;
