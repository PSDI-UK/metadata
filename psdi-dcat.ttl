<http://metadata.psdi.ac.uk/psdi-dcat/guidance/06f88b4e-5d6c-4dc1-8ddd-51099c5bd387> a psdiDcatExt:Guidance ;
    rdfs:label "Sharing Data and FAIR Guidance"^^xsd:string ;
    psdiDcatExt:displayPriority 1e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/knowledgeBaseTopics-r.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Cerys Willoughby and Louise Saul. Sharing Data and FAIR Guidance. Online. Physical Sciences Data Infrastructure (PSDI), 01 January 2025. Available from: https://resources.psdi.ac.uk/guidance/06f88b4e-5d6c-4dc1-8ddd-51099c5bd387. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0003-1721-9212>,
        <http://orcid.org/0009-0000-6422-0342> ;
    dcterms:description "This collection of topics provides guidance on good practices for sharing your research data. This section introduces the FAIR principles and their importance, and provides step by step guidance on what is needed to make your research data and related outputs such as code and methods findable, accessible, interoperable, and reusable, whether or not you share them publicly. Guidance is given on choosing and writing licenses for your data, creating a data package to share or archive, and considerations for choosing a repository."^^xsd:string ;
    dcterms:identifier "psdiDcat:guidance/06f88b4e-5d6c-4dc1-8ddd-51099c5bd387"^^xsd:string ;
    dcterms:issued "2025-01-01T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/CC-BY-4.0.html> ;
    dcterms:modified "2025-01-13T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "Sharing Data and FAIR Guidance"^^xsd:string ;
    dcterms:type dcmitype:Text ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:contactPoint <mailto:support@psdi.ac.uk/> ;
    dcat:inCatalog <http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/dbb09221-f69d-4751-9f51-7623209d2c70> ;
    dcat:keyword "accessibility"^^xsd:string,
        "data"^^xsd:string,
        "fair"^^xsd:string,
        "findability"^^xsd:string,
        "interoperability"^^xsd:string,
        "research"^^xsd:string,
        "reusability"^^xsd:string,
        "reuse"^^xsd:string,
        "sharing"^^xsd:string ;
    dcat:landingPage <https://guidance.psdi.ac.uk/docusaurus-pages/docs/category/sharing-data-and-fair> ;
    dcat:theme <http://metadata.psdi.ac.uk/psdi-voc-subject#multidisciplinary> .

<http://metadata.psdi.ac.uk/psdi-dcat/guidance/0ce7f2d9-d187-4398-b113-947856712ec0> a psdiDcatExt:Guidance ;
    rdfs:label "psdi_shg_exemplar"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/caseStudies-r.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Jeremy G. Frey, Samantha Pearman-Kanza, Stephen Gow, Donald Cruickshank, Jack Doyle and Matthew Partridge. Resurrecting Second Harmonic Generation (SHG) Case Study. Online. 24 April 2025. Available from: https://resources.psdi.ac.uk/guidance/0ce7f2d9-d187-4398-b113-947856712ec0. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0001-5280-8309>,
        <http://orcid.org/0000-0002-0777-0855>,
        <http://orcid.org/0000-0002-4831-9489>,
        <http://orcid.org/0000-0003-0121-1697>,
        <http://orcid.org/0000-0003-0842-4302>,
        <http://www.linkedin.com/in/jack-doyle-175183323> ;
    dcterms:description "The preservation, accessibility, and reuse of scientific data are increasingly vital in contemporary research. Historical datasets, often termed legacy data, provide significant opportunities for new discoveries, validation of past results, and insights through modern analytical methods. Despite their potential value, legacy datasets frequently suffer from poor documentation, outdated formats, and technological obsolescence, complicating their reuse. This report addresses these challenges through the reconstruction of databases originating from Second Harmonic Generation (SHG) experiments, conducted as part of a doctoral research project completed in 2011 at the University of Southampton."^^xsd:string ;
    dcterms:identifier "psdiDcat:guidance/0ce7f2d9-d187-4398-b113-947856712ec0"^^xsd:string ;
    dcterms:issued "2025-04-24T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/CC-BY-4.0.html> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "Resurrecting Second Harmonic Generation (SHG) Case Study"^^xsd:string ;
    dcterms:type dcmitype:Text ;
    adms:status <http://purl.org/adms/status/Completed> ;
    dcat:contactPoint <mailto:support@psdi.ac.uk/> ;
    dcat:inCatalog <http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/61577a4d-ced8-4ebd-9443-88a54b74de1a> ;
    dcat:keyword "second harmonic generation"^^xsd:string ;
    dcat:landingPage <https://doi.org/10.5258/SOTON/PSDI0001> ;
    dcat:theme <http://data.europa.eu/8mn/euroscivoc/5ccac6a4-396a-4789-9506-de4ee54aae3d>,
        <http://publications.europa.eu/resource/authority/8mn/euroscivoc/995f4448-d135-4ba0-925f-e7afa18a0d0e> ;
    prov:qualifiedAttribution [ a prov:Attribution ;
            dcat:hadRole <https://schemas.isotc211.org/Resources/codelists.xml#ISO19115-1.1.cit.CI_RoleCode_author> ;
            prov:agent <http://www.linkedin.com/in/stephen-wilson-017a7150> ] .

