<http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/1c4e7833-32a5-45ce-8c89-b5678de085a5> a dcat:Catalog ;
    rdfs:label "PSDI Subscribed Resources"^^xsd:string ;
    psdiDcatExt:displayPriority 1e+00 ;
    psdiDcatExt:furtherInformation <https://guidance.psdi.ac.uk/docusaurus-pages/docs/category/psdi-subscribed-resources> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/psdiSubscribedResources-r.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_16ec> ;
    dcterms:description "This resource theme brings together trusted proprietary data sources and services developed by external providers, which PSDI subscribes to in order to make them available to its users. These include resources developed by the Cambridge Crystallographic Data Centre (CCDC), FIZ Karlsruhe and DECHEMA. Resources from the CCDC comprise the Cambridge Structural Database (CSD) and associated software which can be accessed through the PSDI Cross Data Search, the CCDC web interface, and via remote desktop. FIZ Karlsruhe develop and maintain the Inorganic Crystal Structure Database (ICSD), which is available in its own search web interface. DECHEMA develop and maintain DETHERM (Thermophysical Property Data) which is available via its own search web interface. Access to these resources requires PSDI login credentials, and certain datasets or tools may be restricted to specific PSDI user groups."^^xsd:string ;
    dcterms:identifier "psdiDcat:resource-theme/1c4e7833-32a5-45ce-8c89-b5678de085a5"^^xsd:string ;
