<http://metadata.psdi.ac.uk/psdi-dcat/service/d81616df-3daf-44c3-98b4-841e277dfe08> a dcat:DataService ;
    rdfs:label "PSDI Community Data Collections"^^xsd:string ;
    psdiDcatExt:displayPriority 1e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/psdi-s-communityDataCollections.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Andrew Harper, Gemma Poulter and Callum Webb. PSDI Community Data Collections. Online. Physical Sciences Data Infrastructure (PSDI), 31 March 2025. Available from: https://resources.psdi.ac.uk/service/d81616df-3daf-44c3-98b4-841e277dfe08. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0009-0001-9720-3378>,
        <http://orcid.org/0009-0005-9011-2472>,
        <http://www.linkedin.com/in/andrew-harper-654456241> ;
    dcterms:description "PSDI Community Data Collections is a collaborative, subject-focused research data repository within the Physical Sciences Data Infrastructure (PSDI). It provides openly accessible datasets, currently serving the BioSim and Data to Knowledge communities, to facilitate the publication, sharing, discovery, and reuse of valuable data. The repository adheres to FAIR principles by implementing a comprehensive metadata schema that incorporates both standard properties and custom fields tailored to scientific needs. Metadata and full datasets are freely available to all users, and plans are in place to expand PSDI Community Data Collections by including additional relevant scientific communities in the future."^^xsd:string ;
    dcterms:identifier "psdiDcat:service/d81616df-3daf-44c3-98b4-841e277dfe08"^^xsd:string ;
    dcterms:issued "2025-03-31T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "PSDI Community Data Collections"^^xsd:string ;
    dcterms:type dcmitype:Service ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:contactPoint <mailto:support@psdi.ac.uk/> ;
    dcat:endpointURL <http://data-collections.psdi.ac.uk> ;
    dcat:keyword "AiiDA"^^xsd:string,
        "FAIR"^^xsd:string,
        "MLIP"^^xsd:string,
        "bio simulations"^^xsd:string,
        "data"^^xsd:string,
        "re-use"^^xsd:string,
        "search"^^xsd:string ;
    dcat:landingPage <http://data-collections.psdi.ac.uk> ;
    dcat:servesDataset <http://metadata.psdi.ac.uk/psdi-dcat/data/771d2ae4-7f19-4258-b144-dc212cef6e43>,
