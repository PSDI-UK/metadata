<http://metadata.psdi.ac.uk/psdi-dcat/data/44160b2f-5938-442e-9f0a-652eb55d1c2b> a dcat:Dataset ;
    rdfs:label "PChProp"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:furtherInformation <https://pchprop-optimade.psdi.ac.uk/>,
        <https://zenodo.org/records/15656342> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/dataCollectionsForChemicalModelling-r.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:accrualPeriodicity <http://purl.org/cld/freq/irregular> ;
    dcterms:bibliographicCitation "Please cite: Jeremy G. Frey, Samantha Pearman-Kanza, Joshua Cheung, Joanna Grundy and Matthew Partridge. Physical Chemistry Properties Data Sets (PChProp). Online. 04 March 2026. Available from: https://resources.psdi.ac.uk/data/44160b2f-5938-442e-9f0a-652eb55d1c2b. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0001-5280-8309>,
        <http://orcid.org/0000-0002-4831-9489>,
        <http://orcid.org/0000-0003-0842-4302>,
        <http://orcid.org/0000-0003-2583-5680>,
        <http://orcid.org/0009-0003-9952-3468> ;
    dcterms:description "These datasets focuses on solubility-related information, including boiling points, Henry's law constants, LogS, melting points, and mole fractions. The Physical Chemistry Properties Data Collection provides carefully curated and standardized data on key chemical properties, empowering researchers to effectively model, analyze, and drive innovation in the field of physical chemistry. These datasets are available via PSDI Cross Data Search (https://data-search.psdi.ac.uk/find-a-substance/molecule?db=psdi.pchprop) and OPTIMADE (https://www.optimade.org/) API endpoints (https://pchprop-optimade.psdi.ac.uk/)."^^xsd:string ;
    dcterms:identifier "psdiDcat:data/44160b2f-5938-442e-9f0a-652eb55d1c2b"^^xsd:string ;
    dcterms:isPartOf <http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/33e34aed-745c-412c-8e90-f11bb2270a38>,
        <http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/e0ed08b6-6d44-4cc8-8385-4929078cd622> ;
    dcterms:issued "2026-03-04T00:00:00+00:00"^^xsd:dateTime ;
