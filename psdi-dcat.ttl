<http://metadata.psdi.ac.uk/psdi-dcat/data/1c588bd2-6c7d-4f74-8b61-426b7d864d3a> a dcat:Dataset ;
    rdfs:label "TEM-ParticlesDB"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:furtherInformation <https://data-collections.psdi.ac.uk/communities/tem-particlesdb/about> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/tempos-r.png> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Andrew Stewart and Natalia Da Silva De Sa. TEM-ParticlesDB: Next-Generation Transmission Electron Microscopy (TEM) images. Online. 19 March 2026. Available from: https://resources.psdi.ac.uk/data/1c588bd2-6c7d-4f74-8b61-426b7d864d3a. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <https://orcid.org/0000-0002-3081-5644>,
        <https://orcid.org/0009-0005-2972-9975> ;
    dcterms:description "TEM-ParticlesDB is an open repository of Transmission Electron Microscopy (TEM) nanoparticle images and associated segmentation data that have been automatically segmented using machine learning to identify particle size, shape and morphology across a range of substrates. Each entry includes the original experimental TEM images, the synthetic training data used to develop the segmentation models, and the resulting segmented particle outlines. The synthetic data is generated using the TEMPOS (Transmission Electron Microscopy Particle Outline Segmentation) software and used to train segmentation models via transfer learning, before being applied to the experimental images."^^xsd:string ;
    dcterms:identifier "psdiDcat:data/1c588bd2-6c7d-4f74-8b61-426b7d864d3a"^^xsd:string ;
    dcterms:issued "2026-03-19T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
