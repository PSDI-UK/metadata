<http://metadata.psdi.ac.uk/psdi-dcat/data/01c14e6c-7dd2-4e25-96f2-75bb02400ed6> a dcat:Dataset ;
    rdfs:label "STFC Open Data"^^xsd:string ;
    psdiDcatExt:displayPriority 3e+00 ;
    psdiDcatExt:furtherInformation <https://edata.stfc.ac.uk/info/edata-guidance> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/psdiCrossSearchData-d-stfcOpenData.png> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:accrualPeriodicity <http://purl.org/cld/freq/irregular> ;
    dcterms:bibliographicCitation "Please cite: STFC Open Data. Online. 29 January 2023. Available from: https://resources.psdi.ac.uk/data/01c14e6c-7dd2-4e25-96f2-75bb02400ed6. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:description "STFC Open Data includes data and software records from STFC's experimental facilities, such as the ISIS Neutron and Muon Source and the Central Laser Facility. This data source also features long-tail data shared by researchers in the STFC eData institutional repository. Any data or software record originating from STFC with a DOI is published in DataCite, which serves as the source for the \"STFC Open Data\" collection in PSDI."^^xsd:string ;
    dcterms:identifier "psdiDcat:data/01c14e6c-7dd2-4e25-96f2-75bb02400ed6"^^xsd:string ;
    dcterms:issued "2023-01-29T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/> ;
    dcterms:publisher <https://ror.org/057g20z61/> ;
    dcterms:title "STFC Open Data"^^xsd:string ;
    dcterms:type dcmitype:Dataset ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:Distribution <http://metadata.psdi.ac.uk/psdi-dcat/distribution/c1e681c2-69ea-491c-984a-be80615a7394> ;
    dcat:contactPoint <mailto:support@psdi.ac.uk/> ;
    dcat:inCatalog <http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/e0ed08b6-6d44-4cc8-8385-4929078cd622> ;
    dcat:keyword "experimental data"^^xsd:string,
        "inelastic neutron scattering"^^xsd:string,
        "laser"^^xsd:string,
        "simulation data"^^xsd:string,
        "spectra"^^xsd:string ;
    dcat:landingPage <https://oai.datacite.org/oai?verb=ListRecords&metadataPrefix=oai_dc&set=BL.STFC> ;
    dcat:theme <http://metadata.psdi.ac.uk/psdi-voc-subject#multidisciplinary> .

<http://metadata.psdi.ac.uk/psdi-dcat/data/06bdf98c-e51b-4656-a424-2c9e80b68c76> a dcat:Dataset ;
    rdfs:label "Chemotion Repository"^^xsd:string ;
    psdiDcatExt:displayPriority 3e+00 ;
    psdiDcatExt:furtherInformation <https://www.chemotion.net/docs/repo> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/psdiCrossSearchData-d-chemotion.png> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:accrualPeriodicity <http://purl.org/cld/freq/irregular> ;
    dcterms:bibliographicCitation "Please cite: Prof. Stefan Bräse, Dr. Nicole Jung, Dr. Pierre Tremouilhac, Pei-Chi Huang, Chia-Lin Lin, Dr. Yu-Chieh Huang, Dr. An Nguyen and Dr. Felix Bach. Chemotion Repository. Online. 25 June 2021. Available from: https://resources.psdi.ac.uk/data/06bdf98c-e51b-4656-a424-2c9e80b68c76. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0001-9513-2468>,
        <http://orcid.org/0000-0002-0487-3947>,
        <http://orcid.org/0000-0002-1692-6778>,
        <http://orcid.org/0000-0002-4261-9886>,
        <http://orcid.org/0000-0002-5035-7978>,
        <http://orcid.org/0000-0002-9772-0455>,
        <http://orcid.org/0000-0002-9976-4507>,
        <http://orcid.org/0000-0003-4845-3191> ;
    dcterms:description "The Chemotion Repository is an open repository of well-structured and machine-readable chemical data created by the Karlsruhe Institute of Technology. The focus of the repository is synthetic and analytical chemistry data. It includes data pertaining to reactions, molecules and physical samples. Data in the repository is uploaded by the community, and is subject to peer review."^^xsd:string ;
    dcterms:identifier "psdiDcat:data/06bdf98c-e51b-4656-a424-2c9e80b68c76"^^xsd:string ;
    dcterms:issued "2021-06-25T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/CC-BY-4.0.html>,
        <https://spdx.org/licenses/CC-BY-SA-4.0.html>,
        <https://spdx.org/licenses/CC0-1.0.html> ;
    dcterms:publisher <http://ror.org/04t3en479/> ;
    dcterms:title "Chemotion Repository"^^xsd:string ;
