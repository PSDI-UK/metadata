<http://metadata.psdi.ac.uk/psdi-dcat/service/7a029bb3-5a5b-474e-8592-679a36d73818> a dcat:DataService ;
    rdfs:label "CDI bibliographic data web service"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/catalysisDataInfrastructure-r.png> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Abraham Nieva De La Hidalga. Catalysis Data Infrastructure (CDI) Bibliographic Data Web Service. Online. Version 0.9. 19 October 2021. Available from: https://resources.psdi.ac.uk/service/7a029bb3-5a5b-474e-8592-679a36d73818. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0001-7348-7612> ;
    dcterms:description "The data of the community portal is accessible programmatically through custom web services (API calls). Each entity can respond to call with JSON data which can be used to create custom views or feed third party applications. For example, the UK catalysis hub uses a web service that delivers filtered bibliographic lists of publications, is used to populate the publications pages on its website and to generate custom reports. We can assist in developing tailored services to meet specific community requirements."^^xsd:string ;
    dcterms:identifier "psdiDcat:service/7a029bb3-5a5b-474e-8592-679a36d73818"^^xsd:string ;
    dcterms:issued "2021-10-19T00:00:00+00:00"^^xsd:dateTime ;
