        <https://orcid.org/0000-0003-2219-3635>,
        <https://orcid.org/0009-0002-4762-5852> ;
    dcterms:description "The PSDI Organic Toolkit is a suite of web apps to support organic chemistry researchers in transparent and high-quality data-reporting. We provide services for visualisation of reaction scope and the variability of numeric reaction outcomes."^^xsd:string ;
