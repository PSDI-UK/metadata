<http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/dac6ab91-fd6e-43e1-b54a-55adc7548b14> a dcat:Catalog ;
    rdfs:label "Galaxy"^^xsd:string ;
    psdiDcatExt:Guidance <http://metadata.psdi.ac.uk/psdi-dcat/guidance/0d209bb0-6bda-4d27-b3f0-10346f9a55b8>,
        <http://metadata.psdi.ac.uk/psdi-dcat/guidance/5bbc1e38-2c64-4752-addd-70920f5159f1>,
