<http://metadata.psdi.ac.uk/psdi-dcat/tool/e03c049a-fac0-4c00-8f71-a61f45d22d4d> a psdiDcatExt:Tool ;
    rdfs:label "TopoStats"^^xsd:string ;
    psdiDcatExt:developmentStatus "Development Status :: 5 - Production/Stable"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:furtherInformation <https://afm-spm.github.io/TopoStats/latest/> ;
    psdiDcatExt:installCommand "pip install topostats"^^xsd:string ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/topostats-r.svg> ;
    psdiDcatExt:operatingSystem "Operating System :: OS Independent"^^xsd:string ;
    psdiDcatExt:programmingLanguage "Programming Language :: Python :: 3; Programming Language :: Python :: 3.10; Programming Language :: Python :: 3.11"^^xsd:string ;
    psdiDcatExt:repositoryURL <https://github.com/AFM-SPM/TopoStats> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Shephard, N., Whittle, S., Gamill, M., Du, M., & Pyne, A. (2023). TopoStats - Atomic Force Microscopy image processing and analysis (Version 2). The University of Sheffield. https://doi.org/10.15131/shef.data.22633528.v2 and Beton, J. G., Moorehead, R., Helfmann, L., Gray, R., Hoogenboom, B. W., Joseph, A. P., Topf, M., & Pyne, A. L. (2021). TopoStats - A program for automated tracing of biomolecules from AFM images. Methods, 193, 68-79. https://doi.org/10.1016/j.ymeth.2021.01.008"^^xsd:string ;
    dcterms:creator <https://github.com/TFirth2>,
        <https://github.com/bobturneruk>,
        <https://github.com/tobyallwood>,
        <https://orcid.org/0000-0001-7499-3867>,
        <https://orcid.org/0000-0001-8301-6857>,
        <https://orcid.org/0000-0002-2658-8987>,
        <https://orcid.org/0000-0002-8919-2701>,
        <https://orcid.org/0000-0003-4615-2379>,
        <https://orcid.org/0009-0007-3250-5299>,
        <https://orcid.org/0009-0008-9164-9513>,
        <https://orcid.org/0009-0008-9452-5719> ;
    dcterms:description "TopoStats is a Python toolkit that automates the processing and analysis of Atomic Force Microscopy (AFM) data. It batch processes raw AFM files to identify molecules or other features, trace their shapes, and generate image outputs at each stage of the workflow. The software produces rich quantitative measurements in both tabular and graphical formats, and is developed in line with FAIR research software principles to support transparent, reproducible AFM analysis."^^xsd:string ;
    dcterms:identifier "psdiDcat:tool/e03c049a-fac0-4c00-8f71-a61f45d22d4d"^^xsd:string ;
    dcterms:issued "2019-01-29T15:00:56+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/GPL-3.0-only.html>,
        <https://spdx.org/licenses/LGPL-3.0-only.html> ;
    dcterms:modified "2026-03-30T15:18:34+00:00"^^xsd:dateTime ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "TopoStats: Batch Processing Atomic Force Microscopy (AFM) Images"^^xsd:string ;
    dcterms:type dcmitype:Software ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:contactPoint <https://github.com/AFM-SPM/TopoStats/issues> ;
    dcat:inCatalog <http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/3e2af553-056d-4c3c-be77-ef13a90c286a> ;
    dcat:keyword "AFM"^^xsd:string,
