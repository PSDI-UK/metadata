    dcat:theme <http://data.europa.eu/8mn/euroscivoc/527ab165-56f2-4020-8975-e7cd3f21d01d> .

<http://metadata.psdi.ac.uk/psdi-dcat/guidance/e29a8e03-eec9-4fd4-9d14-6a86c19938cd> a psdiDcatExt:Guidance ;
    rdfs:label "Making ESI Machine-Readable Case Study"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/caseStudies-r.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Jeremy G. Frey, Samantha Pearman-Kanza, Thomas Allam and Stephen Gow. Making Electronic Supplementary Information (ESI) Machine-Readable Case Study. Online. 24 April 2025. Available from: https://resources.psdi.ac.uk/guidance/e29a8e03-eec9-4fd4-9d14-6a86c19938cd. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0002-4831-9489>,
        <http://orcid.org/0000-0003-0121-1697>,
        <http://orcid.org/0000-0003-0842-4302>,
        <http://orcid.org/0009-0009-9897-333X> ;
    dcterms:description "This case study explores the challenges of losing valuable raw data when it is embedded within PDFs as part of supplementary information (ESIs). To address this, data was extracted from the supplementary information of the paper titled \"Towards the Prediction of Antimicrobial Efficacy for Hydrogen Bonded, Self-Associating Amphiphiles\" (http://doi.org/10.1002/cmdc.202000533) and converted into JSON format. The process was carefully documented to showcase how such data can be transformed into a more machine-readable format, improving accessibility and usability for further analysis."^^xsd:string ;
    dcterms:identifier "psdiDcat:guidance/e29a8e03-eec9-4fd4-9d14-6a86c19938cd"^^xsd:string ;
    dcterms:issued "2025-04-24T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/CC-BY-4.0.html> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "Making Electronic Supplementary Information (ESI) Machine-Readable Case Study"^^xsd:string ;
    dcterms:type dcmitype:Text ;
    adms:status <http://purl.org/adms/status/Completed> ;
