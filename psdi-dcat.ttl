<http://metadata.psdi.ac.uk/psdi-dcat/tool/099911e7-a350-44b7-8add-2cba64beb8d8> a psdiDcatExt:Tool ;
    rdfs:label "Metadise Container (Docker format)"^^xsd:string ;
    psdiDcatExt:deliveryFormat <https://www.iana.org/assignments/media-types/application/vnd.docker.distribution.manifest.v2+json> ;
    psdiDcatExt:developmentStatus "Development Status :: 3 - Alpha"^^xsd:string ;
    psdiDcatExt:displayPriority 3e+00 ;
    psdiDcatExt:downloadURL <https://ghcr.io/psdi-uk/metadise-container/metadise> ;
    psdiDcatExt:furtherInformation <https://github.com/PSDI-UK/metadise-container/blob/main/README.md> ;
    psdiDcatExt:installCommand "docker pull ghcr.io/psdi-uk/metadise-container/metadise:latest"^^xsd:string ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/containerImageRegistry-r.svg> ;
    psdiDcatExt:programmingLanguage "Programming Language :: Fortran; Programming Language :: Unix Shell"^^xsd:string ;
    psdiDcatExt:repositoryURL <https://github.com/PSDI-UK/metadise-container> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Tom Underwood and Stephen C. Parker. Metadise Container (Docker format). Online. Version 0.0.5. 22 April 2025. Available from: https://resources.psdi.ac.uk/tool/099911e7-a350-44b7-8add-2cba64beb8d8. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0001-6431-0612>,
        <https://orcid.org/0000-0003-3804-0975> ;
    dcterms:description "This container image enables users to run the computational chemistry program Metadise on their own computing infrastructure using Docker. Metadise stands for 'Minimum Energy Technique Applied to Dislocation, Interface and Surface Energies'. The program has multiple uses. For instance it can be used to model dislocations, surfaces and grain boundaries at the atomic scale using force fields; and it can be used to create input files for other computational chemistry programs. This container image enables users to use Metadise directly with Metadise input files, removing the need to manually compile Metadise from its source code."^^xsd:string ;
    dcterms:identifier "psdiDcat:tool/099911e7-a350-44b7-8add-2cba64beb8d8"^^xsd:string ;
    dcterms:issued "2025-04-22T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/>,
        <https://spdx.org/licenses/0BSD.html> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "Metadise Container (Docker format)"^^xsd:string ;
    dcterms:type dcmitype:Software ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:contactPoint <https://github.com/PSDI-UK/metadise-container/issues> ;
