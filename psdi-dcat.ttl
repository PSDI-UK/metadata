<http://metadata.psdi.ac.uk/psdi-dcat/tool/f988614a-ab07-4fb6-b0ee-83f19024399d> a psdiDcatExt:Tool ;
    rdfs:label "abcd (MLIP)"^^xsd:string ;
    psdiDcatExt:displayPriority 2.3e+00 ;
    psdiDcatExt:furtherInformation <http://libatoms.github.io/abcd/> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/mlip-r.svg> ;
    psdiDcatExt:repositoryURL <http://github.com/libAtoms/abcd/> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Gábor Csányi. abcd, Data Management for Machine Learning Interatomic Potentials (MLIP). Online. 31 March 2019. Available from: https://resources.psdi.ac.uk/tool/f988614a-ab07-4fb6-b0ee-83f19024399d. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0002-8180-2034> ;
    dcterms:description "abcd, Data Management for Machine Learning Interatomic Potentials (MLIP), offers a suite of tools that allow users to programmatically import data from a repository and utilize it on their local infrastructure. This enables exploration of data in ways that would be too resource-intensive for a general service. Designed specifically for machine-learned interatomic potentials, abcd supports both OpenSearch and MongoDB as backend options, giving users flexibility in their setup. The tool is developed in collaboration with the University of Cambridge."^^xsd:string ;
    dcterms:identifier "psdiDcat:tool/f988614a-ab07-4fb6-b0ee-83f19024399d"^^xsd:string ;
    dcterms:issued "2019-03-31T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/MIT.html> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "abcd, Data Management for Machine Learning Interatomic Potentials (MLIP)"^^xsd:string ;
    dcterms:type dcmitype:Software ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:contactPoint <https://github.com/libAtoms/abcd/issues> ;
    dcat:inCatalog <http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/aa3bd192-f865-45fd-9d0b-b6a9d6071992> ;
    dcat:keyword "MLIP"^^xsd:string,
        "Machine Learning Interatomic Potentials"^^xsd:string,
        "abcd"^^xsd:string ;
    dcat:landingPage <http://github.com/libAtoms/abcd> ;
    dcat:theme <http://data.europa.eu/8mn/euroscivoc/527ab165-56f2-4020-8975-e7cd3f21d01d> .

<http://metadata.psdi.ac.uk/psdi-dcat/tool/fa4cf273-773f-48b3-aace-7aebdbc27306> a psdiDcatExt:Tool ;
