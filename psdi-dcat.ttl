<http://metadata.psdi.ac.uk/psdi-dcat/service/6bc7c64d-ee3d-430b-be09-f26040886c3c> a dcat:DataService ;
    rdfs:label "PSDI Cross Data Search"^^xsd:string ;
    psdiDcatExt:displayPriority 1e+00 ;
    psdiDcatExt:furtherInformation <http://psdi-uk.github.io/docusaurus-pages/docs/guidance/psdi-resources/cross-data-search/> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/psdi-s-crossDataSearch.svg> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Mehmet Giritli, Callum Webb and Gemma Poulter. PSDI Cross Data Search. Online. Version 1.1.0. Physical Sciences Data Infrastructure (PSDI), 31 March 2025. Available from: https://resources.psdi.ac.uk/service/6bc7c64d-ee3d-430b-be09-f26040886c3c. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0009-0001-7735-0100>,
        <http://orcid.org/0009-0001-9720-3378>,
        <http://orcid.org/0009-0005-9011-2472> ;
    dcterms:description "The PSDI Cross Data Search service enables users to search for data across data sources provided by PSDI and other relevant data sources from the wider community using our online interface. The service provides a number of different ways to perform a search, for example searching substances by chemical formula, name, or number of elements, with the option to refine searches using a periodic table interface. Specialised searches can also be performed for molecules using  molecular structures, crystalline forms, or specific symmetry or periodicity characteristics. There is also an advanced search option, enabling custom queries to be constructed for users who know which fields in the data sources they want to search. The search results provide both a summary of the data and links to the source of the data. Although the majority of data sources are completely open, authentication may be required for some data sources."^^xsd:string ;
    dcterms:identifier "psdiDcat:service/6bc7c64d-ee3d-430b-be09-f26040886c3c"^^xsd:string ;
    dcterms:issued "2025-03-31T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "PSDI Cross Data Search"^^xsd:string ;
    dcterms:type dcmitype:Service ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:contactPoint <mailto:support@psdi.ac.uk/> ;
    dcat:endpointURL <http://data-search.psdi.ac.uk> ;
    dcat:keyword "chemical structures"^^xsd:string,
        "data"^^xsd:string,
        "download"^^xsd:string,
        "search"^^xsd:string ;
    dcat:landingPage <http://data-search.psdi.ac.uk> ;
    dcat:servesDataset <http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/e0ed08b6-6d44-4cc8-8385-4929078cd622> ;
    dcat:theme <http://metadata.psdi.ac.uk/psdi-voc-subject#multidisciplinary> ;
    dcat:version "1.1.0"^^xsd:string .

