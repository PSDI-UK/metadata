    psdiDcatExt:installCommand "apptainer pull oras://ghcr.io/psdi-uk/metadise-container/metadise-sif:latest"^^xsd:string ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/containerImageRegistry-r.svg> ;
    psdiDcatExt:programmingLanguage "Programming Language :: Fortran; Programming Language :: Unix Shell"^^xsd:string ;
    psdiDcatExt:repositoryURL <https://github.com/PSDI-UK/metadise-container> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Tom Underwood and Stephen C. Parker. Metadise Container (SIF format). Online. Version 0.0.5. 22 April 2025. Available from: https://resources.psdi.ac.uk/tool/a95c572b-634d-4682-9533-5d4787164997. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0001-6431-0612>,
        <https://orcid.org/0000-0003-3804-0975> ;
    dcterms:description "This container image enables users to run the computational chemistry program Metadise on their own computing infrastructure using Singularity or Apptainer. Metadise stands for 'Minimum Energy Technique Applied to Dislocation, Interface and Surface Energies'. The program has multiple uses. For instance it can be used to model dislocations, surfaces and grain boundaries at the atomic scale using force fields; and it can be used to create input files for other computational chemistry programs. This container image enables users to use Metadise directly with Metadise input files, removing the need to manually compile Metadise from its source code."^^xsd:string ;
    dcterms:identifier "psdiDcat:tool/a95c572b-634d-4682-9533-5d4787164997"^^xsd:string ;
    dcterms:issued "2025-04-22T00:00:00+00:00"^^xsd:dateTime ;
