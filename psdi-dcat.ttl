<http://metadata.psdi.ac.uk/psdi-dcat/service/d9556f5e-9a66-4ae6-ab20-d2235957c22b> a dcat:DataService ;
    rdfs:label "Web Access to Inorganic Crystal Structure Database (ICSD Web)"^^xsd:string ;
    psdiDcatExt:displayPriority 1e+00 ;
    psdiDcatExt:furtherInformation <https://guidance.psdi.ac.uk/docusaurus-pages/docs/guidance/psdi-resources/data-sources/subscribed/icsd/>,
        <https://icsd.products.fiz-karlsruhe.de/en/about/about-icsd>,
        <https://icsd.products.fiz-karlsruhe.de/en/products/icsd-products#icsd+web> ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/psdiSubscribedResources-d-icsd.png> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_16ec> ;
    dcterms:bibliographicCitation """The most recent publication:
Zagorac, D., Muller, H., Ruehl, S., Zagorac, J. & Rehme, S., J. Appl. Cryst. 52 (2019), 918-925; DOI: 10.1107/S160057671900997X                                                                                                                                                                                                                                                                                                                                        
Original publication:
Bergerhoff, G. & Brown, I.D. in "Crystallographic Databases", F.H. Allen et al. (Hrsg.) Chester, International Union of Crystallography, (1987)."""^^xsd:string ;
    dcterms:creator <https://ror.org/0387prb75/> ;
    dcterms:description "The Inorganic Crystal Structure Database (ICSD), maintained by FIZ Karlsruhe, is the world's largest collection of fully identified inorganic crystal structures, containing more than 325,000 entries. It includes experimentally determined inorganic and organometallic structures as well as theoretically calculated inorganic structures, and also provides simulated powder diffraction data. Each record contains rich structural information, including unit cell parameters, space group, full atomic coordinates, site occupation factors, Wyckoff positions, molecular and ANX formulas, molecular weight, and mineral group. Access to ICSD through PSDI is available to authenticated users within the UK academic community. The search interface provides a set of tools designed to support efficient discovery and analysis of crystal structure data. Its capabilities include an intuitive search environment, extensive structure type classifications that can be queried using descriptive parameters, and structure standardisation features that make comparison across entries straightforward. Users can explore structures through advanced visualisation and analysis tools, generate and manipulate simulated powder diffraction patterns, and manage queries through a simple but flexible interface. Direct links to the original literature are also provided via an OpenURL server."^^xsd:string ;
    dcterms:identifier "psdiDcat:service/d9556f5e-9a66-4ae6-ab20-d2235957c22b"^^xsd:string ;
    dcterms:issued "2019-07-01T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://www.fiz-karlsruhe.de/sites/default/files/ICSD/documents/terms/ICSD_AGB_E_2021.pdf> ;
    dcterms:modified "2026-04-13T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:publisher <https://ror.org/0387prb75/> ;
    dcterms:title "Web Access to Inorganic Crystal Structure Database (ICSD Web)"^^xsd:string ;
    dcterms:type dcmitype:Service ;
    adms:status <http://purl.org/adms/status/Completed> ;
    dcat:contactPoint <mailto:support@psdi.ac.uk/> ;
    dcat:endpointURL <https://icsd-web.psdi.ac.uk> ;
    dcat:inCatalog <http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/1c4e7833-32a5-45ce-8c89-b5678de085a5> ;
    dcat:keyword "PSDS"^^xsd:string,
        "Physical Sciences Data-Science Service"^^xsd:string,
        "crystal structure"^^xsd:string,
        "crystalline structure"^^xsd:string,
        "experimental data"^^xsd:string,
        "inorganic crystal"^^xsd:string,
        "organometallic crystal"^^xsd:string,
        "theoretical data"^^xsd:string ;
    dcat:landingPage <https://icsd-web.psdi.ac.uk> ;
    dcat:theme <http://data.europa.eu/8mn/euroscivoc/61a310a8-87ce-448c-b5e5-28feab37defe>,
        <http://data.europa.eu/8mn/euroscivoc/9e5be1eb-bf25-4136-a4e5-2c68aa7cd80a>,
        <http://data.europa.eu/8mn/euroscivoc/e9da6561-23b9-48ac-9377-b68b13393e77> ;
    prov:qualifiedAttribution [ a prov:Attribution ;
            dcat:hadRole <https://schemas.isotc211.org/Resources/codelists.xml#ISO19115-1.1.cit.CI_RoleCode_originator> ;
            prov:agent <https://orcid.org/0000-0002-6267-2692> ],
        [ a prov:Attribution ;
            dcat:hadRole <https://schemas.isotc211.org/Resources/codelists.xml#ISO19115-1.1.cit.CI_RoleCode_originator> ;
            prov:agent <https://www.webofscience.com/wos/author/record/ENO-4093-2022> ] .

<http://metadata.psdi.ac.uk/psdi-dcat/service/f350b410-23d2-4c25-9a7d-51d7d0263537> a dcat:DataService ;
    rdfs:label "PSDI Data Revival Service"^^xsd:string ;
    psdiDcatExt:displayPriority 1e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/dataRevival-r.png> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_16ec> ;
    dcterms:bibliographicCitation "Please cite: Samuel Munday, Samantha Pearman-Kanza, Jeremy G. Frey, Ashley Unitt, Louis McLean, Daniel Cancado, Yuehua Yin and Cheryl Hardy. PSDI Data Revival Service. Online. Available from: https://resources.psdi.ac.uk/service/f350b410-23d2-4c25-9a7d-51d7d0263537. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <http://orcid.org/0000-0001-5404-6934>,
        <http://orcid.org/0000-0002-4831-9489>,
        <http://orcid.org/0000-0003-0842-4302>,
        <http://orcid.org/0009-0004-2240-0109>,
        <http://orcid.org/0009-0005-1180-1326>,
        <http://orcid.org/0009-0005-7585-3432>,
        <http://orcid.org/0009-0006-2746-7104>,
        <http://orcid.org/0009-0007-0037-0035> ;
    dcterms:description "The majority of laboratories and research groups have stacks of paper notebooks filled with valuable data that is difficult and time-consuming to access and use. Data Revival is an AI-driven service that can seamlessly convert your handwritten lab book pages into machine-readable data, unlocking the potential of your chemistry data. Operating with a high degree of accuracy, Data Revival creates relational links across your chemical data and enables users to run semantic searches across potentially millions of data points, including complex chemical structures. PSDI offers users the chance to experience Data Revival's capabilities firsthand."^^xsd:string ;
    dcterms:identifier "psdiDcat:service/f350b410-23d2-4c25-9a7d-51d7d0263537"^^xsd:string ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "PSDI Data Revival Service"^^xsd:string ;
    dcterms:type dcmitype:Service ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:contactPoint <mailto:contact@data-revival.com/> ;
