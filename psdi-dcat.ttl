<http://metadata.psdi.ac.uk/psdi-dcat/tool/323cc7d7-4538-47ca-bdd3-ab02194b7834> a psdiDcatExt:Tool ;
    rdfs:label "TEMPOS Github Repository"^^xsd:string ;
    psdiDcatExt:developmentStatus "Development Status :: 4 - Beta"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/tempos-r.png> ;
    psdiDcatExt:programmingLanguage "Programming Language :: Python"^^xsd:string ;
    psdiDcatExt:repositoryURL <https://github.com/AMCLab/TEMPOS> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Andrew Stewart and Natalia Da Silva De Sa. TEMPOS (Transmission Electron Microscopy Particle Outline Segmentation) Github Repository. Online. Version 1.0.0. 14 April 2026. Available from: https://resources.psdi.ac.uk/tool/323cc7d7-4538-47ca-bdd3-ab02194b7834. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <https://orcid.org/0000-0002-3081-5644>,
        <https://orcid.org/0009-0005-2972-9975> ;
    dcterms:description """TEMPOS is software used to segment TEM nanoparticle images by generating synthetic training data and training segmentation models that underpin the datasets in TEM ParticlesDB. It provides a graphical interface for creating synthetic TEM images, applying contrast transfer functions, training segmentation models, and processing experimental images to produce particle outlines and measurements.
For users who want to reproduce or extend the workflow, the repository also includes Jupyter notebooks for segmenting TEM videos, with or without particle tracking, and scripts for running the full method outside the GUI. These materials allow researchers to explore how the segmentation models were trained, adapt the workflow to their own data, or generate additional synthetic datasets for further model development."""^^xsd:string ;
    dcterms:identifier "psdiDcat:tool/323cc7d7-4538-47ca-bdd3-ab02194b7834"^^xsd:string ;
    dcterms:issued "2026-04-14T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://spdx.org/licenses/GPL-3.0-only.html> ;
    dcterms:modified "2026-04-14T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "TEMPOS (Transmission Electron Microscopy Particle Outline Segmentation) Github Repository"^^xsd:string ;
    dcterms:type dcmitype:Software ;
    adms:status <http://purl.org/adms/status/UnderDevelopment> ;
    dcat:contactPoint <https://github.com/AMCLab/TEMPOS/issues> ;
    dcat:inCatalog <http://metadata.psdi.ac.uk/psdi-dcat/resource-theme/27774cac-6e13-4602-a547-ae5c68032a75> ;
