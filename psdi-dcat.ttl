<http://metadata.psdi.ac.uk/psdi-dcat/guidance/97557d0d-af8e-4ce2-97f4-f943e21e3925> a psdiDcatExt:Guidance ;
    rdfs:label "TEMPOS Documentation"^^xsd:string ;
    psdiDcatExt:displayPriority 2e+00 ;
    psdiDcatExt:logoURL <https://raw.githubusercontent.com/PSDI-UK/psdi-common-style/refs/heads/main/store/resource-catalogue-logos/tempos-r.png> ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:bibliographicCitation "Please cite: Andrew Stewart and Natalia Da Silva De Sa. TEMPOS (Transmission Electron Microscopy Particle Outline Segmentation) Documentation. Online. 14 April 2026. Available from: https://resources.psdi.ac.uk/guidance/97557d0d-af8e-4ce2-97f4-f943e21e3925. [accessed YYYY-MM-DD]."^^xsd:string ;
    dcterms:creator <https://orcid.org/0000-0002-3081-5644>,
        <https://orcid.org/0009-0005-2972-9975> ;
    dcterms:description "This guidance resource provides full documentation, supported by walkthrough videos, on how to use TEMPOS, the graphical interface for generating synthetic TEM data, applying CTF, training Detectron2 segmentation models, processing experimental images, and exporting data locally with Datasette. It includes an overview of the software, instructions for setting up the required environment, step by step guidance for running the tool, installation notes for Windows users, and options for more advanced execution."^^xsd:string ;
    dcterms:identifier "psdiDcat:guidance/97557d0d-af8e-4ce2-97f4-f943e21e3925"^^xsd:string ;
    dcterms:issued "2026-04-14T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:modified "2026-04-14T00:00:00+00:00"^^xsd:dateTime ;
    dcterms:publisher <http://www.psdi.ac.uk/> ;
    dcterms:title "TEMPOS (Transmission Electron Microscopy Particle Outline Segmentation) Documentation"^^xsd:string ;
    dcterms:type dcmitype:Text ;
